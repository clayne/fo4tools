#!/bin/bash

# Data/DLCNukaWorld.esm_precombine_merge.esp
# Data/DLCCoast.esm.previs_merge.main.01.esp

set -e

MODE="$1"; shift
MODE=( ${MODE//,/ } )
ESM=( "$@" )

# XXX: Fix this by having ckgen handle things or something else
CKGEN_OUT=ckgen.out; export CKGEN_OUT

for mode in ${MODE[*]}; do
	if [[ "$mode" == "precombined" ]]; then
		echo "Merging precombines..."

		# XXX: Use -dumpneededfiles here!
		# Used purely for interactive CK + xedit workflow
		find Data/*[_.]precombine_merge*.esp -type f -name '*.esp' -printf '%f\n' -prune | parallel -r --lb -j6 '
			set -e
			esp_bn="{}"
			esm=${esp_bn/[_.]precombine_merge*}
			if [[ -f "Data/$esm" ]]; then
				echo "./CreationKit -checkinplugin:{} $esm && cp -p Data/Merging/$esm Data/$esm" 1>&2
				./CreationKit -checkinplugin:{} $esm && cp -p Data/Merging/$esm Data/$esm
			else
				echo "Data/$esm" does not exist 1>&2
			fi
		'

		# XXX: Not able to be used yet
		continue

		find "$CKGEN_OUT" -type d -name '*.esm' -printf '%f\n' -prune | parallel -r --lb -j6 '
			set -e
			find "$CKGEN_OUT/{}" -type f -name '*[_.]precombine_merge*.esp' -printf "%p %f\n" | while read esp esp_bn; do
				esm=${esp_bn/[_.]precombine_merge*}
				if [[ -f "Data/$esm" ]]; then
					ln -f "$esp" "Data/$esp_bn" || exit -1
					echo "./CreationKit -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm" 1>&2
					./CreationKit -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm
				else
					echo "Data/$esm" does not exist 1>&2
				fi
			done
		'

		for esm in ${ESM[*]}; do
			rsync -avSP --link-dest="$PWD/$CKGEN_OUT/$esm/Data/Meshes/PreCombined" "$CKGEN_OUT/$esm/Data/Meshes/PreCombined"/ "Data/Meshes/PreCombined"/
		done
	elif [[ "$mode" == "previs" ]]; then
		echo "Merging previs..."

		find "$CKGEN_OUT" -type d -name '*.esm' -printf '%f\n' -prune | parallel -r --lb -j6 '
			set -e
			find "$CKGEN_OUT/{}" -type f -name '*[_.]previs_merge*.esp' -printf "%p %f\n" | while read esp esp_bn; do
				esm=${esp_bn/[_.]previs_merge*}
				if [[ -f "Data/$esm" ]]; then
					ln -f "$esp" "Data/$esp_bn" || exit -1
					echo "./CreationKit -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm" 1>&2
					./CreationKit -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm
				else
					echo "Data/$esm" does not exist 1>&2
				fi
			done
		'

		for esm in ${ESM[*]}; do
			rsync -avSP --link-dest="$PWD/$CKGEN_OUT/$esm/Data/Vis" "$CKGEN_OUT/$esm/Data/Vis"/ "Data/Vis"/
		done
	fi
done
