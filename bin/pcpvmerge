#!/bin/bash

# Data/DLCNukaWorld.esm_precombine_merge.esp
# Data/DLCCoast.esm.previs_merge.main.01.esp

set -e

DUMPNEEDED=0
MERGE=0

while getopts "dm" opt; do
	case $opt in
	d) DUMPNEEDED=1 ;;
	m) MERGE=1 ;;
	?) exit -1 ;;
	esac
done; shift $((OPTIND - 1))

MODE="$1"; shift
MODE=( ${MODE//,/ } )
ESM=( "$@" )

# XXX: Fix this by having ckgen handle things or something else
CKGEN_OUT=ckgen.out; export CKGEN_OUT

for mode in ${MODE[*]}; do
	case "$mode" in
	precombine)
		if ((MERGE)); then
			# XXX: Check if Merging/<esm> exists before doing anything
			# Used purely for interactive CK + xedit workflow
			echo "Merging precombines... (CK)"
			find Data/*[_.]precombine_merge*.esp -type f -name '*.esp' -printf '%f\n' -prune | parallel -r --lb -j6 '
				set -e
				esp_bn="{}"
				esm=${esp_bn/[_.]precombine_merge*}
				if [[ -f "Data/$esm" ]]; then
					echo "./CreationKit.exe -checkinplugin:{} $esm && cp -p Data/Merging/$esm Data/$esm" 1>&2
					./CreationKit.exe -checkinplugin:{} $esm && cp -p Data/Merging/$esm Data/$esm
					echo "./CreationKit.exe -dumpneededfiles:{} Data/{}.needed.out" 1>&2
					./CreationKit.exe -dumpneededfiles:{} Data/{}.needed.out
					cat Data/{}.needed.out | tr -d '[\r\0\031]' | tr '\\' '/' \
						> Data/{}.needed.out.tmp && mv Data/{}.needed.out.tmp Data/{}.needed.out
				else
					echo "Data/$esm" does not exist 1>&2
				fi
			'
		fi

		if ((DUMPNEEDED)); then
			# XXX: Check if Merging/<esm> exists before doing anything
			# Used purely for interactive CK + xedit workflow
			find Data/*[_.]precombine_merge*.esp -type f -name '*.esp' -printf '%f\n' -prune | parallel -r --lb -j6 '
				set -e
				esp_bn="{}"
				esm=${esp_bn/[_.]precombine_merge*}
				if [[ -f "Data/$esm" ]]; then
					echo "./CreationKit.exe -dumpneededfiles:{} Data/{}.needed.out" 1>&2
					./CreationKit.exe -dumpneededfiles:{} Data/{}.needed.out
					cat Data/{}.needed.out | tr -d '[\r\0\031]' | tr '\\' '/' \
						> Data/{}.needed.out.tmp && mv Data/{}.needed.out.tmp Data/{}.needed.out
				else
					echo "Data/$esm" does not exist 1>&2
				fi
			'
		fi

		if ((MERGE)); then
			# XXX: Check if Merging/<esm> exists before doing anything
			echo "Merging precombines..."
			find "$CKGEN_OUT" -type d -name '*.esm' -printf '%f\n' -prune | parallel -r --lb -j6 '
				set -e
				find "$CKGEN_OUT/{}" -type f -name '*[_.]precombine_merge*.esp' -printf "%p %f\n" | while read esp esp_bn; do
					esm=${esp_bn/[_.]precombine_merge*}
					if [[ -f "Data/$esm" ]]; then
						ln -f "$esp" "Data/$esp_bn" || exit -1
						echo "./CreationKit.exe -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm" 1>&2
						./CreationKit.exe -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm
					else
						echo "Data/$esm" does not exist 1>&2
					fi
				done
			'
		fi
		;;
	previs)
		if ((MERGE)); then
			# XXX: Check if Merging/<esm> exists before doing anything
			echo "Merging previs..."
			find "$CKGEN_OUT" -type d -name '*.esm' -printf '%f\n' -prune | parallel -r --lb -j6 '
				set -e
				find "$CKGEN_OUT/{}" -type f -name '*[_.]previs_merge*.esp' -printf "%p %f\n" | while read esp esp_bn; do
					esm=${esp_bn/[_.]previs_merge*}
					if [[ -f "Data/$esm" ]]; then
						ln -f "$esp" "Data/$esp_bn" || exit -1
						echo "./CreationKit.exe -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm" 1>&2
						./CreationKit.exe -checkinplugin:$esp_bn $esm && cp -p Data/Merging/$esm Data/$esm
					else
						echo "Data/$esm" does not exist 1>&2
					fi
				done
			'
		fi
		;;
	*)
		echo "Unknown mode: $mode" 1>&2
		exit -1
		;;
	esac

	for esm in ${ESM[*]}; do
		esm=$(basename $esm);
		rsync -avSP \
			--include '*precombine_merge*.esp' \
			--include '*previs_merge*.esp' \
			--exclude '*' \
			--link-dest="$PWD/$CKGEN_OUT/$esm/Data" \
			"$CKGEN_OUT/$esm/Data"/ "Data"/
	done
done
