my $patch_tab = {
	'1.10.15.0' => {
		 offset => 0x34713e,
		sum_pre => 'fc3ceb06c3181303347d352d234000b0',
		sum_pst => '3d258f581ba4b7f9517785471a6bbce1',
		arg_pre => "\x01",
		arg_pst => "\x00",
	},
	'1.10.130.0' => {
		 offset => 0x34713e,
		sum_pre => '0574a5718ea8f7f09864d6d9416eaaac',
		sum_pst => '4517020fef2ce4946cfe0d739ccd7b93',
		arg_pre => "\x01",
		arg_pst => "\x00",
	},
	'1.10.162.0' => {
		 offset => 0x34726e,
		sum_pre => 'e46b959103e4962b379c10e7686476e6',
		sum_pst => '184ec94a07df461ca8ba09e4a4a8e2f2',
		arg_pre => "\x01",
		arg_pst => "\x00",
	},
};
my $patch_xtab;

foreach my $version (keys %$patch_tab) {
	foreach (qw(sum_pre sum_pst)) {
		$patch_xtab->{$patch_tab->{$version}{$_}} = $patch_tab->{$version};
	}
}

sub file_sum {
	my $file = shift;
	my $file_sz = (stat($file))[7] or die "stat: $file: $!";
	my $buf;

	open(my $fd, '<', $file) or die "open: $file: $!";
	binmode($fd);
	sysread($fd, $buf, $file_sz, 0) or die "sysread: $file: $!";
	close($fd);

	return md5_hex($buf);
}

sub file_patch {
	my $file = shift;
	my $data = shift;
	my $offset = shift;
	my $sum_pst = shift;
	my $file_sz = (stat($file))[7] or die "stat: $file: $!";
	my $buf;

	my $file_temp = "$file.$$";

	copy($file, $file_temp) or die "copy: $file -> $file_temp";

	open(my $fd, '+<', $file_temp) or die "open: $file_temp: $!";
	binmode($fd);
	seek($fd, $offset, 0) or die "seek: $file_temp: $!";
	syswrite($fd, $data, length($data)) or die "syswrite: $file_temp: $!";
	close($fd);

	my $file_sum = file_sum($file_temp);
	print STDERR Dumper { sum_pst => $sum_pst, sum_patched => $file_sum } if ($verbose > 1);

	if ($file_sum ne $sum_pst) {
		print STDERR "$_: file_sum != sum_pst ($file_sum != $sum_pst)\n";
		unlink($file_temp) or die "unlink: $file_temp: $!";
		return 0;
	}

	rename($file_temp, $file) or die "rename: $file_temp -> $file: $!";

	return 1;
}

sub main {
	my $ret = 1;
	my $help = 0;
	my $noop = 0;
	my $reverse;

	local @ARGV = @_;
	GetOptions(
                'h|help' => \$help,
		'v|verbose+' => \$verbose,
		'r|reverse+' => \$reverse,
		'n|dry-run+' => \$noop,
        ) && (!$help && ($ret = 1));

        $ret || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	foreach (@ARGV) {
		my $sum = file_sum($_);
		print STDERR Dumper { $_ => $sum } if ($verbose > 1);

		# already patched
		my $ent = $patch_xtab->{$sum};
		if (!$ent) {
			print STDERR "$_: Unknown checksum: $sum\n";
			next;
		}

		print STDERR Dumper { ent => $ent } if ($verbose > 1);

		my ($sum_pre, $sum_pst) = map $ent->{$_}, ($reverse ? qw(sum_pst sum_pre) : qw(sum_pre sum_pst));
		my ($offset, $data) = map $ent->{$_}, ($reverse ? qw(offset arg_pre) : qw(offset arg_pst));

		if ($sum_pst eq $sum) {
			print STDERR "$_: already patched\n" if ($verbose);
		} elsif ($sum_pre eq $sum) {
			print STDERR "$_: patching\n" if ($verbose);
			file_patch($_, $data, $offset, $sum_pst) or $ret = 0;
		} else {
			die "Assertion failed";
		}
	}

	return $ret;
}

exit !main(@ARGV) unless (caller);

__END__
