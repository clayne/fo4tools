#!/usr/bin/perl

use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling pass_through);
use Carp qw(confess);
use File::Basename qw(dirname basename);
use File::Temp qw(tempfile tempdir);
use File::Copy qw(copy);
use File::Spec;
use List::Util qw(first);
use Data::Dumper;
use Pod::Usage;
use IPC::Run qw(run start finish);
use Cwd qw(getcwd);

use strict;
use warnings FATAL => qw(all);

local $SIG{__DIE__} = \&confess;
sub fatal { local $SIG{__DIE__}; die @_, "\n" };

local $Data::Dumper::Sortkeys = 1;

our $VERSION = '$Id$';

# Autohotkey specific
my $autohotkey_path = '/cygdrive/c/Program Files/AutoHotkey/AutoHotkey.exe',

# xedit specific
my $xedit_wrap_path = "$ENV{'HOME'}/git/fo4tools/xedit/ahk/xedit_wrap.ahk";
my $xedit_path = 'fo4edit.exe';
my $xedit_settings_suffix = 'fo4viewsettings';
my $xedit_default_settings = "plugins.$xedit_settings_suffix";
my @xedit_default_args = qw(
        -iknowwhatimdoing
        -allowmasterfilesedit
	-allowdirectsaves
);
#	-pseudoesl
#	-iknowillbreakmygamewiththis
my @xedit_default_script_args = qw(
        -autoload
        -autoexit
);

my $pcvgen_script = 'Fallout4 - Precombined split.pas';
my $pcvgen_plugin_file_default = 'Plugins.txt';
my @pcvgen_plugin_files = qw(
	plugins.pcvgen.base
	plugins.pcvgen
);
my @pcvgen_area = qw(
	main
	ints
	other
);

my $conf = {};
my $log_file;
my $log_prefix = basename($0);
my $autohotkey = 1;
my $verbose = 0;
my $noop = 0;

# Bash-based conf files
my @conf_dirs = ("$ENV{'HOME'}/git/fo4tools/etc", '/usr/local/etc');
my $fo4tools_conf = first { -f } map File::Spec->catfile($_, 'fo4tools.conf'), @conf_dirs;
my $ckgen_conf = first { -f } map File::Spec->catfile($_, 'ckgen.conf'), @conf_dirs;

sub conf_get {
	my $conf = shift;
	my $key = shift || die;

	return $conf->{$key};
}

sub conf_read {
	my $conf = shift;
	my $conf_file = shift || die;

	open(my $fd, '<', $conf_file) or return;
	while (<$fd>) {
		chomp;
		my ($key, $val) = /^([^#=]+)=['"](.+)['"]$/ or next;
		$val =~ s/\$([A-Z0-9_]+)/$ENV{$1}/g;
		$conf->{$key} = $val;
	}
	close($fd);

	return $conf;
}

sub data_dir_resolve {
	my $area = shift || die;
	my $data_dir = shift || die;

	my @data_dirs = (
		"$data_dir/$area",
		$data_dir,
		'Data',
		getcwd,
	);

	foreach (@data_dirs) {
		-d && return $_;
	}

	fatal "Unable to resolve data dir";
}

sub plugin_file_resolve {
	my $area = shift || die;
	my $plugin_file = shift || die;
	my $data_dir = shift || die;
	my $user_dir = shift || die;

	my @plugin_file_dirs = (
		join('/', $data_dir, $area),
		$data_dir,
		'Data',
		getcwd,
		join('/', $user_dir, 'Fallout4'),
	);

	foreach (map +($plugin_file !~ /^\// ? "$_/$plugin_file" : $plugin_file), @plugin_file_dirs) {
		print STDERR Dumper { plugin_file_resolve => $_ } if ($verbose > 1);
		-f && return $_;
	}

	fatal "Unable to resolve plugin file";
}

sub xedit_run {
	my %opts = @_;
	my ($area, $args, $script, $data_dir, $user_dir, $plugin_file)
		= map $opts{$_}, qw(area args script data_dir user_dir plugin_file);
	my @cmds;

	# Shim autohotkey script into cmds so it runs first.
	if ($script) {
		if (! -f "Edit Scripts/$script") {
			die "Unable to find 'Edit Scripts/$script'";
		}
		if ($autohotkey && -x $autohotkey_path) {
			chomp(my $xedit_wrap_path = qx/cygpath -wa "$xedit_wrap_path"/);
			unshift @cmds, [ $autohotkey_path, $xedit_wrap_path ], '&';
		}
	}

	foreach my $area (@$area) {
		my $data_dir = data_dir_resolve($area, $data_dir);
		my $plugin_file = plugin_file_resolve($area, $plugin_file, $data_dir, $user_dir);

		# If <plugin_file (last extension removed).fo4viewsettings> doesn't exist, copy
		# an existing one using the default name (usually 'plugins.fo4viewsettings').
		my $plugin_file_base = ($plugin_file =~ /\./) ? ($plugin_file =~ /(.+)\..+$/)[0] : $plugin_file;
		my $plugin_settings = join('.', $plugin_file_base, $xedit_settings_suffix);
		if (! -f $plugin_settings) {
			foreach (
				$xedit_default_settings,
				join('/', $user_dir, 'Fallout4', $xedit_default_settings),
			) {
				next unless -f;

				copy($_, $plugin_settings) unless ($noop);
				last;
			}
		}

		my $pcv_mode = (map /--pcv-mode=(.+)/, @$args)[0];
		my $log_file = $log_file || join('.', grep $_, ($log_prefix, $pcv_mode, $area, 'log'));
		my $log_output_file = join('.', grep $_, ($log_prefix, $pcv_mode, $area, 'out'))
			unless (grep /--pcv-plugin-output-(?:log|log-prefix)=/, @$args);

		chomp(my $log_file_dos = qx/cygpath -aw "$log_file"/);
		chomp(my $plugin_file_dos = qx/cygpath -aw "$plugin_file"/);
		chomp(my $data_dir_dos = qx/cygpath -aw "$data_dir"/);

#		my $temp_dir = tempdir(CLEANUP => 1);
#		chomp(my $temp_dir_dos = qx/cygpath -aw "$temp_dir"/);

		my ($in, $out, $err);
		my @cmd = (
			$xedit_path,
#			"-T:$temp_dir_dos",
			"-R:$log_file_dos",
			"-P:$plugin_file_dos",
			"-D:$data_dir_dos",
			@xedit_default_args,
			$script ? (
				@xedit_default_script_args,
				"-script:$script",
			) : (),
			map {
				# If any args contain embedded '$area' values, substitute them with
				# the actual area being executed on.
				s/\$area/$area/gr;
			} @$args,
			$log_output_file ? "--pcv-plugin-output-log=$log_output_file" : (),
			$area ? "--pcv-area=$area" : (),
		);

		print STDERR join(' ', map +(/\s/ ? "'$_'" : $_), @cmd), "\n" if ($verbose || $noop);

		push @cmds, \@cmd, '&';
	}

	if (!$noop && @cmds) {
		# look for xedit in the current directory
		local $ENV{'PATH'} = join(':', getcwd, $ENV{'PATH'});
		run @cmds;
	}
}

sub plugins_tmp_write {
	my %seen;
	my ($fh, $tmpfile) = tempfile(UNLINK => 0);
	foreach (@_) {
		next if ($seen{$_}++);
		printf $fh ("%s%s\n", ($_ !~ /^\*/ ? '*' : ''), $_);
	}
	close($fh);
	return $tmpfile;
}

sub stdin_or_file {
	return ($_[0] eq '' || $_[0] eq '-') ? '/dev/stdin' : $_[0];
}

sub main {
	my $help = 0;
	my @area = ();
	my @pcvgen_args = ();
	my $ckgen_data_dir;
	my $fo4tools_user_dir;
	my $plugin_file_tmp;
	my $plugin_file;
	my @plugin_files;
	my @plugins;
	my $ret = 1;

	conf_read($conf, $fo4tools_conf);
	conf_read($conf, $ckgen_conf);

	local @ARGV = @_;

	GetOptions(
		's|script=s' => \$pcvgen_script,
		'd|data-dir=s' => \$ckgen_data_dir,
		'u|user-dir=s' => \$fo4tools_user_dir,
		'x|xedit-args=s' => \@xedit_default_args,
		'p|plugin-files:s' => sub { push @plugin_files, $_[1] && split(',', $_[1]) },
		'a|area=s' => sub { push @area, split(',', $_[1]) },
		'l|log=s' => \$log_file,
		'i|interactive+' => sub { $pcvgen_script = '' },
		'n|dry-run|noop+' => \$noop,
		'ahk|autohotkey!' => \$autohotkey,
		'verbose|v+' => \$verbose,
                'h|help' => \$help,
		'<>' => sub {
			local $_ = $_[0];
			push @{/^(?:main|ints|other|all)$/ ? \@area
				: /^--/ ? \@pcvgen_args
				: \@plugins}, $_[0];
		},
        ) && !$help || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	# defaults if no command line options
	$ckgen_data_dir ||= join('/', getcwd, conf_get($conf, 'CKGEN_DATA_DIR'));
	$fo4tools_user_dir ||= conf_get($conf, 'DATADIR');
	@area = @pcvgen_area unless (@area);

	# command line args always win first
	if (!scalar @plugins) {
		if (!$plugin_file) {
			# use default plugin files if none specified
			@plugin_files = (grep -f, @pcvgen_plugin_files) unless (@plugin_files);

			foreach (map stdin_or_file($_), @plugin_files) {
				open(my $fd, '<', $_) or die "open: $_: $!";
				while (<$fd>) { s/\R//g; s/^\*//g; push @plugins, $_ };
				close($fd) or die "close: $_: $!";
			}
		}
	}

	$plugin_file_tmp = plugins_tmp_write(@plugins) if (@plugins);
	$plugin_file ||= $plugin_file_tmp || $pcvgen_plugin_file_default;

	my %xedit_run_args = (
		area => \@area,
		args => \@pcvgen_args,
		script => $pcvgen_script,
		plugin_file => $plugin_file,
		data_dir => $ckgen_data_dir,
		user_dir => $fo4tools_user_dir,
	);

	print STDERR Dumper { %xedit_run_args } if ($verbose > 1);
	eval { xedit_run(%xedit_run_args) };
	if ($@) {
		print STDERR $@;
		$ret = 0;
	}

	if ($plugin_file_tmp) {
		foreach ($plugin_file_tmp, "$plugin_file_tmp.$xedit_settings_suffix") {
			-f && unlink($_);
		}
	}

	return $ret;
}

exit !main(@ARGV) unless (caller);

__END__
