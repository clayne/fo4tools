#!/usr/bin/perl

use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling pass_through);
use Carp qw(confess);
use Data::Dumper;
use Pod::Usage;
use IPC::Run qw(run start finish);
use Cwd qw(getcwd);

use strict;
use warnings FATAL => qw(all);

local $SIG{__DIE__} = \&confess;
sub fatal { local $SIG{__DIE__}; die @_, "\n" };

local $Data::Dumper::Sortkeys = 1;

our $VERSION = '$Id$';

# Autohotkey specific
my $autohotkey_path = '/cygdrive/c/Program Files/AutoHotkey/AutoHotkey.exe',
my $xedit_wrap_path = "$ENV{'HOME'}/git/fo4tools/xedit/ahk/xedit_wrap.ahk";

# XXX: assumes default location
my $fallout_dir = '/cygdrive/c/Program Files (x86)/Steam/steamapps/common/Fallout 4';
my $pcvgen_script='Fallout4 - Precombined split.pas';
my $pcvgen_plugin_file='plugins.pcvgen';
my @pcvgen_area = qw(
	main
	ints
	other
);
my $ckgen_data_dir='ckgen.data';
my @xedit_default_args = qw(
        -iknowwhatimdoing
        -allowmasterfilesedit
);
my @xedit_default_script_args = qw(
        -autoload
        -autoexit
);

my $verbose = 0;
my $noop = 0;

sub data_dir_resolve {
	my $area = shift || die;
	my $data_dir = shift || die;

	foreach ("$data_dir/$area", "$data_dir", "Data", getcwd) {
		-d && return $_;
	}

	fatal "Unable to resolve data dir";
}

sub plugin_file_resolve {
	my $area = shift || die;
	my $plugin_file = shift || die;

	foreach (map "$_/$plugin_file", "$ckgen_data_dir/$area", "$ckgen_data_dir", "Data", getcwd) {
		-f && return $_;
	}

	fatal "Unable to resolve plugin file";
}

sub xedit_run {
	my %opts = @_;
	my ($area, $args, $script, $data_dir, $plugin_file) = map $opts{$_}, qw(area args script data_dir plugin_file);
	my @cmds;

	# Shim autohotkey script into cmds so it runs first.
	if ($script && -x $autohotkey_path) {
		chomp(my $xedit_wrap_path = qx/cygpath -wa "$xedit_wrap_path"/);
		unshift @cmds, [ $autohotkey_path, $xedit_wrap_path ], '&';
	}

	foreach my $area (@$area) {
		my $data_dir = data_dir_resolve($area, $data_dir);
		my $plugin_file = plugin_file_resolve($area, $plugin_file);

		chomp(my $data_dir_dos = qx/cygpath -aw "$data_dir"/);
		chomp(my $plugin_file_dos = qx/cygpath -aw "$plugin_file"/);

		my ($in, $out, $err);
		my @cmd = (
			"./fo4edit.exe",
			"-P:$plugin_file_dos",
			"-D:$data_dir_dos",
			@xedit_default_args,
			$script ? (
				@xedit_default_script_args,
				"-script:$script",
			) : (),
			@$args,
			"--pcv-area=$area",
		);

		print STDERR join(' ', map +(/\s/ ? "'$_'" : $_), @cmd), "\n" if ($verbose);

		push @cmds, \@cmd, '&';
	}

	eval { run @cmds } if (@cmds);
}

sub main {
	my $ret;
	my $help = 0;
	my @area = ();
	my @pcvgen_args = ();

	local @ARGV = @_;

	GetOptions(
		'p|plugins=s' => \$pcvgen_plugin_file,
		's|script=s' => \$pcvgen_script,
		'g|gamedir=s' => \$fallout_dir,
		'd|data-dir=s' => \$ckgen_data_dir,
		'x|xargs=s' => \@xedit_default_args,
		'a|area=s' => sub { push @area, split(',', $_[1]) },
		'i|interactive+' => sub { $pcvgen_script = '' },
		'n|dry-run|noop+' => \$noop,
		'verbose|v+' => \$verbose,
                'h|help' => \$help,
		'<>' => sub { push @{$_[0] =~ /^(?:main|ints|other)$/ ? \@area : \@pcvgen_args}, $_[0] },
        ) && !$help || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	@area = qw(main ints other) unless (@area);

	print STDERR Dumper { area => \@area, pcvgen_args => \@pcvgen_args, verbose => $verbose } if ($verbose > 1);

	xedit_run(
		area => \@area,
		args => \@pcvgen_args,
		script => $pcvgen_script,
		plugin_file => $pcvgen_plugin_file,
		data_dir => $ckgen_data_dir,
	);

	return 1;
}

exit !main(@ARGV) unless (caller);

__END__
