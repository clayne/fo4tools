#!/usr/bin/perl

use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling pass_through);
use Carp qw(confess);
use File::Basename qw(dirname basename);
use File::Temp qw(tempfile tempdir);
use File::Copy qw(copy);
use Data::Dumper;
use Pod::Usage;
use IPC::Run qw(run start finish);
use Cwd qw(getcwd);

use strict;
use warnings FATAL => qw(all);

local $SIG{__DIE__} = \&confess;
sub fatal { local $SIG{__DIE__}; die @_, "\n" };

local $Data::Dumper::Sortkeys = 1;

our $VERSION = '$Id$';

my $fo4tools_conf = '/usr/local/etc/fo4tools.conf';

# Autohotkey specific
my $autohotkey_path = '/cygdrive/c/Program Files/AutoHotkey/AutoHotkey.exe',
my $xedit_wrap_path = "$ENV{'HOME'}/git/fo4tools/xedit/ahk/xedit_wrap.ahk";

my $ckgen_data_dir='ckgen.data';
my $pcvgen_script='Fallout4 - Precombined split.pas';
my $pcvgen_plugin_file='plugins.pcvgen';
my @pcvgen_area = qw(
	main
	ints
	other
);
my $xedit_default_settings = 'plugins.fo4viewsettings';
my @xedit_default_args = qw(
        -iknowwhatimdoing
        -allowmasterfilesedit
	-allowdirectsaves
);
#	-pseudoesl
#	-iknowillbreakmygamewiththis
my @xedit_default_script_args = qw(
        -autoload
        -autoexit
);

my $conf = {};

my $autohotkey = 1;
my $verbose = 0;
my $noop = 0;

sub conf_read {
	my $conf = shift || die;
	my $tmp = {};

	open(my $fd, '<', $conf) or die "open: $conf: $!";
	while (<$fd>) {
		chomp;
		my ($key, $val) = /^([^=]+)="(.+)"$/ or next;
		$val =~ s/\$([A-Z0-9_]+)/$ENV{$1}/g;
		$tmp->{$key} = $val;
	}
	close($fd);

	return $tmp;
}

sub data_dir_resolve {
	my $area = shift || die;
	my $data_dir = shift || die;

	foreach ("$data_dir/$area", "$data_dir", 'Data', getcwd) {
		-d && return $_;
	}

	fatal "Unable to resolve data dir";
}

sub plugin_file_resolve {
	my $area = shift || die;
	my $plugin_file = shift || die;

	foreach (map +($_ ? "$_/$plugin_file" : $plugin_file), "$ckgen_data_dir/$area", "$ckgen_data_dir", 'Data', getcwd, '') {
		-f && return $_;
	}

	fatal "Unable to resolve plugin file";
}

sub xedit_run {
	my %opts = @_;
	my ($area, $args, $script, $data_dir, $plugin_file) = map $opts{$_}, qw(area args script data_dir plugin_file);
	my @cmds;

	# Shim autohotkey script into cmds so it runs first.
	if ($script) {
		if (! -f "Edit Scripts/$script") {
			die "Unable to find 'Edit Scripts/$script'";
		}
		if ($autohotkey && -x $autohotkey_path) {
			chomp(my $xedit_wrap_path = qx/cygpath -wa "$xedit_wrap_path"/);
			unshift @cmds, [ $autohotkey_path, $xedit_wrap_path ], '&';
		}
	}

	foreach my $area (@$area) {
		my $data_dir = data_dir_resolve($area, $data_dir);
		my $plugin_file = plugin_file_resolve($area, $plugin_file);

		# If <plugin_file (last extension removed).fo4viewsettings> doesn't exist, copy
		# an existing one using the default name (usually 'plugins.fo4viewsettings').
		my $plugin_file_base = ($plugin_file =~ /\./) ? ($plugin_file =~ /(.+)\..+$/)[0] : $plugin_file;
		my $plugin_settings = join('.', $plugin_file_base, 'fo4viewsettings');
		if (! -f $plugin_settings) {
			foreach (
				$xedit_default_settings,
				join('/', $conf->{'DATADIR'}, 'Fallout4', $xedit_default_settings),
			) {
				next unless -f;

				copy($_, $plugin_settings);
				last;
			}
		}

		chomp(my $log_file_dos = qx/cygpath -aw "pcvgen_xe.$area.log"/);
		chomp(my $plugin_file_dos = qx/cygpath -aw "$plugin_file"/);
		chomp(my $data_dir_dos = qx/cygpath -aw "$data_dir"/);

#		my $temp_dir = tempdir(CLEANUP => 1);
#		chomp(my $temp_dir_dos = qx/cygpath -aw "$temp_dir"/);

		my ($in, $out, $err);
		my @cmd = (
			"./fo4edit.exe",
#			"-T:$temp_dir_dos",
			"-R:$log_file_dos",
			"-P:$plugin_file_dos",
			"-D:$data_dir_dos",
			@xedit_default_args,
			$script ? (
				@xedit_default_script_args,
				"-script:$script",
			) : (),
			@$args,
			"--pcv-area=$area",
		);

		print STDERR join(' ', map +(/\s/ ? "'$_'" : $_), @cmd), "\n" if ($verbose);

		push @cmds, \@cmd, '&';
	}

	eval { run @cmds } if (@cmds);
}

sub plugins_tmp_write {
	my ($fh, $tmpfile) = tempfile(UNLINK => 0);
	foreach (@_) { printf $fh ("%s%s\n", ($_ !~ /^\*/ ? '*' : ''), $_) }
	close($fh);
	return $tmpfile;
}

sub main {
	my $ret;
	my $help = 0;
	my @area = ();
	my @pcvgen_args = ();
	my @plugins;
	my $tmpfile;

	$conf = conf_read($fo4tools_conf);

	local @ARGV = @_;

	GetOptions(
		'p|plugins:s' => \$pcvgen_plugin_file,
		's|script=s' => \$pcvgen_script,
		'd|data-dir=s' => \$ckgen_data_dir,
		'x|xedit-args=s' => \@xedit_default_args,
		'a|area=s' => sub { push @area, split(',', $_[1]) },
		'i|interactive+' => sub { $pcvgen_script = '' },
		'n|dry-run|noop+' => \$noop,
		'ahk|autohotkey!' => \$autohotkey,
		'verbose|v+' => \$verbose,
                'h|help' => \$help,
		'<>' => sub {
			local $_ = $_[0];
			push @{/^(?:main|ints|other|all)$/ ? \@area : /^--/ ? \@pcvgen_args : \@plugins}, $_[0];
		},
        ) && !$help || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	# Read plugins from stdin if none specified (XXX: handle argv?)
	if (scalar @plugins) {
		$tmpfile = plugins_tmp_write(@plugins);
		$pcvgen_plugin_file = $tmpfile;
	} elsif (!$pcvgen_plugin_file || $pcvgen_plugin_file eq '-' || $pcvgen_plugin_file eq '/dev/stdin') {
		while (<STDIN>) {
			chomp;
			push @plugins, $_;
		}
		$tmpfile = plugins_tmp_write(@plugins);
		$pcvgen_plugin_file = $tmpfile;
	}

	@area = qw(main ints other) unless (@area);

	print STDERR Dumper { area => \@area, pcvgen_args => \@pcvgen_args, verbose => $verbose } if ($verbose > 1);

	xedit_run(
		area => \@area,
		args => \@pcvgen_args,
		script => $pcvgen_script,
		plugin_file => $pcvgen_plugin_file,
		data_dir => $ckgen_data_dir,
	);

	unlink($tmpfile) if ($tmpfile);

	return 1;
}

exit !main(@ARGV) unless (caller);

__END__
