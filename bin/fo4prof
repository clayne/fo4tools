#!/bin/bash

set -e

source "$HOME/git/fo4tools/etc/fo4tools.conf" || source /usr/local/etc/fo4tools.conf

# Force Windows (rather than Cygwin) compatible symlinks
# Note: Requires admin rights or group policy to create symbolic links
# Note: this is also used by rsync when syncing symbolic links.
export CYGWIN=winsymlinks:nativestrict

link() {
	local target="$1"
	local link="$2"

	if [[ ! -e "$target" ]]; then
		echo "'$target' does not exist" 1>&2
		exit -1
	elif [[ -e "$link" && ! -L "$link" ]]; then
		# Do not touch anything if $link is actually a directory
		# or otherwise. It should either not exist or be a symlink.
		echo "'$link' is not a symlink" 1>&2
		exit -1
	fi

	if ((JUNCTIONS)); then
		# mklink cannot overwrite links
		rm -f "$link"

		# mklink [[/d] | [/h] | [/j]] <Link> <Target>
		cmd /c mklink /j "$(cygpath -aw "$link")" "$(cygpath -aw "$target")" >/dev/null
	else
		# ln [OPTION]... [-T] TARGET LINK_NAME   (1st form)
		ln -sfT "$target" "$link"
	fi
}

list() {
	ACTIVE=$(basename "$(readlink.exe -e "$PROGDIR/Fallout 4")" | cut -f 2 -d .)

	find "$PROGDIR/Fallout 4."* -type d -prune -printf "%f\n" 2>/dev/null | cut -f 2 -d . | while read tmp; do
		[[ $tmp == "shared" || $tmp == "template" || $tmp == "extract" ]] && continue
		[[ $tmp == $ACTIVE ]] && echo "$tmp*" || echo "$tmp"
	done
}

delete() {
	while getopts "" opt; do
		case $opt in
		?) exit -1 ;;
		esac
	done; shift $((OPTIND - 1))

	for p in "$@"; do
		rm -rf "$PROGDIR/Fallout 4.$p" "$USERDIR/Fallout4.$p" "$DATADIR/Fallout4.$p"
		((VERSION_CONTROL)) && net share "Merging.$p" /delete >/dev/null || true
	done
}

use() {
	while getopts "" opt; do
		case $opt in
		?) exit -1 ;;
		esac
	done; shift $((OPTIND - 1))

	PROFILE="$1"; shift || true
	if [[ -z "$PROFILE" ]]; then
		echo "No profile specified" 1>&2
		exit -1
	elif [[ ! -d "$PROGDIR/Fallout 4.$PROFILE" ]]; then
		echo "$PROGDIR/Fallout 4.$PROFILE does not exist!" 1>&2
		exit -1
	elif [[ ! -d "$USERDIR/Fallout4.$PROFILE" ]]; then
		echo "$USERDIR/Fallout4.$PROFILE does not exist!" 1>&2
		exit -1
	elif [[ ! -d "$DATADIR/Fallout4.$PROFILE" ]]; then
		echo "$DATADIR/Fallout4.$PROFILE does not exist!" 1>&2
		exit -1
	fi

	link "$PROGDIR/Fallout 4.$PROFILE" "$PROGDIR/Fallout 4"
	link "$USERDIR/Fallout4.$PROFILE" "$USERDIR/Fallout4"
	link "$DATADIR/Fallout4.$PROFILE" "$DATADIR/Fallout4"
}

# XXX: Handle multiple args
new() {
	while getopts "s:" opt; do
		case $opt in
		s) PROFILE_SRC="$OPTARG" ;;
		?) exit -1 ;;
		esac
	done; shift $((OPTIND - 1))

	PROFILE="$1"; shift || true
	if [[ -z "$PROFILE" ]]; then
		echo "No profile specified" 1>&2
		exit -1
	elif [[ -d "$PROGDIR/Fallout 4.$PROFILE" ]]; then
		echo "$PROGDIR/Fallout 4.$PROFILE already exists!" 1>&2
		exit -1
	elif [[ -d "$USERDIR/Fallout4.$PROFILE" ]]; then
		echo "$USERDIR/Fallout4.$PROFILE already exists!" 1>&2
		exit -1
	elif [[ -d "$DATADIR/Fallout4.$PROFILE" ]]; then
		echo "$DATADIR/Fallout4.$PROFILE already exists!" 1>&2
		exit -1
	fi

	PROGDIR_SHARED_BASE="$PROGDIR_SHARED"
	USERDIR_SHARED_BASE="$USERDIR_SHARED"
	DATADIR_SHARED_BASE="$DATADIR_SHARED"

	if [[ -n "$PROFILE_SRC" ]]; then
		PROGDIR_SHARED="$PROGDIR/Fallout 4.$PROFILE_SRC"
		USERDIR_SHARED="$USERDIR/Fallout4.$PROFILE_SRC"
		DATADIR_SHARED="$DATADIR/Fallout4.$PROFILE_SRC"

		# XXX: template copying is probably unnecessary when using -s
		# XXX: because the entire source has already been rsynced
		PROGDIR_TEMPLATE="$PROGDIR/Fallout 4.$PROFILE_SRC"
		USERDIR_TEMPLATE="$USERDIR/Fallout4.$PROFILE_SRC"
		DATADIR_TEMPLATE="$DATADIR/Fallout4.$PROFILE_SRC"
	fi

	# Clone shared directory using hard links only so as to effectively share
	# the files between profiles but consume no additional disk space.
	[[ -d "$PROGDIR_SHARED" ]] && rsync -aSH --link-dest="$PROGDIR_SHARED_BASE" "$PROGDIR_SHARED"/ "$PROGDIR/Fallout 4.$PROFILE"/

	# XXX: This shouldn't be needed twice but without it Fallout4.exe isn't being synced
	[[ -d "$PROGDIR_SHARED" ]] && rsync -aSH --link-dest="$PROGDIR_SHARED_BASE" "$PROGDIR_SHARED"/ "$PROGDIR/Fallout 4.$PROFILE"/

	[[ -d "$USERDIR_SHARED" ]] && rsync -aSH --link-dest="$USERDIR_SHARED_BASE" "$USERDIR_SHARED"/ "$USERDIR/Fallout4.$PROFILE"/
	[[ -d "$DATADIR_SHARED" ]] && rsync -aSH --link-dest="$DATADIR_SHARED_BASE" "$DATADIR_SHARED"/ "$DATADIR/Fallout4.$PROFILE"/

	# For the template directories, hard copy (and overwrite) into profile directory.
	# Any modifications to these files will be per-profile and explicitly not shared.
	[[ -d "$PROGDIR_TEMPLATE" ]] && rsync -aSH "$PROGDIR_TEMPLATE"/ "$PROGDIR/Fallout 4.$PROFILE"/
	[[ -d "$USERDIR_TEMPLATE" ]] && rsync -aSH "$USERDIR_TEMPLATE"/ "$USERDIR/Fallout4.$PROFILE"/
	[[ -d "$DATADIR_TEMPLATE" ]] && rsync -aSH "$DATADIR_TEMPLATE"/ "$DATADIR/Fallout4.$PROFILE"/

	# Convert paths in templated CreationKit.ini to be per-profile specific.
	SFILEPATH=$(cygpath -w "$PROGDIR/Fallout 4.$PROFILE" | sed -e 's#\\#\\\\#g')
	SNETPATH=$(cygpath -w "$PROGDIR/Fallout 4.$PROFILE" | sed -e 's#\\#\\\\#g')

	# XXX: Clean this up to use a more proper ini editing tool/function
	# The insane backslash stuff is due to both shell escaping + sed escaping
	for i in CreationKit.ini CreationKitPrefs.ini CreationKitCustom.ini; do
		[[ -f "$PROGDIR/Fallout 4.$PROFILE/$i" ]] || continue
		sed -i \
			-e "s#^sFile Path=.*\\\\#sFile Path=$SFILEPATH\\\\#g" \
			"$PROGDIR/Fallout 4.$PROFILE/$i"

		if ((VERSION_CONTROL)); then
			# SNetwork Path=\\HOSTNAME\Merging.PROFILE\
			# SNetworkMasterPath=\\HOSTNAME\Merging.PROFILE\
			# SNewVersionBackupPath=\\HOSTNAME\Merging.PROFILE\VersionBackup\
			sed -i \
				-e "s#^SNetwork Path=.*\\\\#SNetwork Path=\\\\\\\\localhost\\\\Merging.$PROFILE\\\\#g" \
				-e "s#^SNetworkMasterPath=.*\\\\#SNetworkMasterPath=\\\\\\\\localhost\\\\Merging.$PROFILE\\\\#g" \
				-e "s#^SNewVersionBackupPath=.*\\\\#SNewVersionBackupPath=\\\\\\\\localhost\\\\Merging.$PROFILE\\\\VersionBackup\\\\#g" \
				"$PROGDIR/Fallout 4.$PROFILE/$i"
		fi
	done

	if ((VERSION_CONTROL)); then
		cat <<-EOF >> "$PROGDIR/Fallout 4.$PROFILE/CreationKitPrefs.ini"
		[WhoCanMerge]
		$USER=1
		EOF

		mkdir -p "$PROGDIR/Fallout 4.$PROFILE/Data/Merging/VersionBackup"
		cp -p "$PROGDIR/Fallout 4.$PROFILE/Data"/*.esm "$PROGDIR/Fallout 4.$PROFILE/Data/Merging"

		net share "Merging.$PROFILE"="C:\Program Files (x86)\Steam\steamapps\common\Fallout 4.$PROFILE\Data\Merging" /grant:$USERNAME,full >/dev/null
	fi

#	esmlocalize -d "$PROGDIR/Fallout 4.$PROFILE/Data/Merging"/*.esm
}

while getopts "" opt; do
        case $opt in
	?) exit -1 ;;
        esac
done; shift $((OPTIND - 1))

MODE="$1"; shift || true

if [[ -z "$MODE" ]]; then
	MODE="list"
fi

case "$MODE" in
list)
	list "$@" ;;
create|new|clone)
	new "$@" ;;
rm|delete|clean)
	delete "$@" ;;
switch|use|flip)
	use "$@" ;;
*)
	use "$MODE" ;;
esac
