#!/bin/bash

set -e
#set -o pipefail

source "$HOME/git/fo4tools/etc/fo4tools.conf" || source /usr/local/etc/fo4tools.conf

# Prereq check
for i in tmux rsync parallel lockfile; do
	if ! which $i &>/dev/null; then
		echo "$i not found" 1>&2
		exit -1
	fi
done

function cpu_core_cnt() {
	awk '/cpu cores/ && !seen[$NF]++ { print $NF }' /proc/cpuinfo
}

function cpu_thread_cnt() {
	egrep -c '^processor[[:space:]]+' /proc/cpuinfo
}

# XXX: Handle plugin:area/<shards>,area/<shards> *and* plugin/shards
function plugin_parse() {
	local tmp _p _t _a _s

	# Thankfully this "grammar" is unambiguous enough..
	OIFS="$IFS"
	IFS=":"
	tmp=( ${1%%/[0-9]} )
	_p=$(basename "${tmp[0]}")
	IFS="/:,"
	tmp=( ${1/${tmp[0]}} )
	IFS="$OIFS"

	for i in ${tmp[*]}; do
		# plugin:clean:ints,other/2 (clean ints,other 2)
		# plugin:clean:ints (clean ints SHARDS)
		# plugin:clean/2 (clean all 2)
		# plugin:ints/4 (TYPE ints 4)
		# plugin:clean (clean AREA SHARDS)
		# plugin:ints (TYPE ints SHARDS)
		# plugin/4 (TYPE AREA 4)
		case "$i" in
		filtered|clean) _t="$i" ;;
		all|main|ints|other) _a="${_a:+$_a,}$i" ;;
		[0-9]*) _s="$i" ;;
		*) echo "Unknown option: $i" 1>&2; exit -1 ;;
		esac
	done

	# Bash really sucks for this type of thing
	eval "$2=\"$_p\"; $3=\"$_t\"; $4=\"$_a\"; $5=\"$_s\""
}

function ctl_log() {
	echo -e "$2\t$3\t$4\t$5\t$6\t$7" >> "$1"
}

function ck_ini_rewrite() {
	# Enable multiple instances (so multiple copies can be run in parallel).
	# Disable version control (so inability to check out a cell isn't an issue).
	# Disable stopping on "important" warnings (so combined data warnings don't stop previs generation).
	# Keep plugins that are merged with -checkinplugin (otherwise records merged and removed from the plugin).
	# Force a few other previs related settings explicitly (even though they're the same as default).
	# Force sFile Path to point to the build directory (precautionary as CK will use the cwd by default).
	# Set umbra threads to core count (default is 4).
	#
	# iMaxUmbraBakeThreads=8
	# bExportSceneOnUmbraGenerate=0
	# bExportTomeOnUmbraGenerate=0
	# bGeneratePreCombinedGeometryPreVis=1
	# bKeepPluginWhenMerging=1
	# bHideImportantWarnings=1
	# bUseVersionControl=0
	#

	set -e
	set -o pipefail

	local wpwd=$(cygpath -aw "$build/$job/")
	awk -v threads=$(cpu_thread_cnt) -v wpwd="${wpwd//\\/\\\\}\\\\" '
	{ 
		if (match($0, "^\\[([^\\]]+)\\]", a)) {
			section=a[1];
			slist[++slidx]=section;
		} else if ($0 !~ /^$/ && match($0, "^([^=;]+) ?= ?([^\r\n]+)[\r\n]?$", a)) {
			shash[section][a[1]]=a[2];
		}
	}END{
#		shash["Memory"]["bEnableMemoryTracking"]=1;
#		shash["General"]["bChangingLotsOfBaseObjects"]=1;
#		shash["General"]["bAllowClearOldestBufferedExterior"]=1;
#		shash["General"]["bMinimizeCachedExteriors"]=1;
#		shash["General"]["bPreemptivelyUnloadCells"]=1;
		shash["General"]["bSkipValidateForms"]=1;
		shash["General"]["bSkipValidateInfos"]=1;
		shash["General"]["bSkipProgramFlows"]=1;
		shash["General"]["bSkipInitializationFlows"]=1;
		shash["General"]["bThrowProcessCompleteExceptions"]=0;
		shash["General"]["iNumHWThreads"]=threads;
		shash["General"]["iMaxJobThreads"]=threads;
		shash["General"]["iMaxUmbraBakeThreads"]=threads;
		shash["General"]["bExportSceneOnUmbraGenerate"]=0;
		shash["General"]["bExportTomeOnUmbraGenerate"]=0;
		shash["General"]["bGeneratePreCombinedGeometryPreVis"]=1;
		shash["General"]["bKeepPluginWhenMerging"]=1;
		shash["General"]["bHideImportantWarnings"]=1;
		shash["General"]["bAllowMultipleEditors"]=1;
		shash["General"]["bAllowMultipleMasterLoads"]=1;
		shash["General"]["bLoadTheUserPlugin"]=0;
		shash["General"]["bUseVersionControl"]=0;
		shash["Archive"]["bInvalidateOlderFiles"]=1;
		shash["Archive"]["sResourceDataDirsFinal"]="";
		shash["General"]["sFile Path"]=wpwd;

		for (i = 1; i <= slidx; i++) {
			section=slist[i];
			printf("%s[%s]\r\n", i > 1 ? "\r\n" : "", section);

			if (!length(shash[section]))
				continue;
			asorti(shash[section], ss_src);

			for (j = 1; j <= length(ss_src); j++) {
				hk = ss_src[j];
				printf("%s=%s\r\n", hk, shash[section][hk]);
			}
		}
	}'
}

function ck_clone() {
	local src="$1"; shift
	local build="$1"; shift
	local out="$1"; shift
	local cache="$1"; shift
	local mode="$1"; shift
	local job="$1"; shift

	set -e
	set -o pipefail

	case "$mode" in
	precombine)
		EXCLUDE_AUX=(
			"--exclude '*.cdx'" \
			"--exclude '*.psg'" \
			"--exclude '*.csg'" \
		)
		;;
	esac

	# Hardlink base directory contents to per-build directories
	rsync -aSH \
		--delete \
		--delete-excluded \
		--exclude "${out}*" \
		--exclude "${build}*" \
		--exclude "${cache}*" \
		--exclude [pP]reCombined* \
		--exclude [vV]is* \
		--exclude [iI]nterface \
		--exclude [sS]trings \
		--exclude [sS]cripts \
		--exclude [tT]extures \
		--exclude [sS]ound \
		--exclude [mM]usic \
		--exclude [vV]ideo \
		--exclude MCM \
		--exclude F4SE \
		--exclude Backup \
		--exclude Edit\ Scripts \
		--exclude CheckinBackup \
		--exclude VersionBackup \
		--exclude log.txt \
		--exclude EditorWarnings.txt \
		--exclude output.tome \
		--exclude input.scene \
		--exclude input.scene.json \
		--exclude CombinedObjects.esp \
		--exclude PreVis.esp \
		--exclude 'CreationKit*.ini' \
		--exclude 'enbseries' \
		--exclude 'auto_backup_executable' \
		--exclude 'FO4Edit*' \
		--exclude 'f4se*.dll' \
		--exclude 'x3d*.dll' \
		--exclude 'd3d*.dll' \
		--exclude 'la_d3d*.dll' \
		${EXCLUDE_AUX[*]} \
		--link-dest="$src" "$src"/ "$build/$job"/
#		--exclude '*.es[pm]' \
#			--exclude "$SELF*" \

	# Hardcopy CK ini files
	rsync -aS --include 'CreationKit*.ini' --exclude '*' "$src"/ "$build/$job"/

#	# Hardcopy plugins
#	rsync -aS --include '*.es[pm]' --exclude '*' "$src/Data"/ "$build/$job/Data"/

#	# Hardcopy plugins (modified)
#	if [[ -d "$src/Data/ckgen" ]]; then
#		rsync -aS "$src/Data/ckgen"/ "$build/$job/Data/ckgen"/
#	fi

	# Hardlink temporary archives (if any) into build-dir (this won't affect the original archives)
	if [[ -d "$cache/Data" ]]; then
		rsync -aSH --link-dest="$src/$cache/Data" "$src/$cache/Data"/ "$build/$job/Data"/
	fi

	# XXX: Update comment (it's the presence of share dirs in the ini that make CK aware of VC)
	# Nuke version control directory to prevent CK from prompting that VC is disabled and
	# move any esms into place as they should be considered the most up to date.
	if [[ -d "$build/$job/Data/Merging" ]]; then
		find "$build/$job/Data/Merging" -maxdepth 1 -type f -name '*.esm' -print0 | xargs -tr0 mv -t "$build/$job/Data"
		rm -rf "$build/$job/Data/Merging"
	fi

	# Alter build-dir versions of CK ini files
	for j in "$build/$job/CreationKit.ini" "$build/$job/CreationKitPrefs.ini" "$build/$job/CreationKitCustom.ini"; do
		[[ -f "$j" ]] && ck_ini_rewrite < "$j" > "$j.tmp" && mv "$j.tmp" "$j"
	done

	return 0
}

function ck_wrap_archive_rename() {
	local -a q=( "$@" )

	set -e
	set -o pipefail

	while ((${#q[*]})); do
		local plugin="${q[0]}"; q=( "${q[@]:1}" )

		local plugin_base="${plugin/%.es[pm]}"
		local plugin_esm="${plugin/%.esp/.esm}"
		local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
		local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
		local plugin_ck_base="${plugin_ck/%.es[pm]}"

		archive_tmp="$bdir/$job/.archive_tmp/Data"
		archive_main="$bdir/$job/Data/$plugin_base - Main.ba2"
		archive_main_ck="$bdir/$job/Data/$plugin_ck_base - Main.ba2"
		archive_main_ck_cached="$cdir/Data/$plugin_ck_base - Main.ba2"
		archive_main_ck_tmp="$archive_tmp/$plugin_ck_base - Main.ba2"
		cache_lock="$cdir/tmp/$plugin.lock"

		# Check if the original plugin's name is anywhere
		# in it's main archive file. If found, extract it's
		# archive, rename any directories to the new name of
		# the plugin, and repackage it as a new archive.

		if [[ ! -f "$archive_main" ]]; then
			continue
		elif ! fgrep -q "$plugin" "$archive_main"; then
			continue
		elif ! lockfile -1 -r 0 "$cache_lock"; then
			echo "Waiting on $cache_lock ..." 1>&2
			q+=( "$plugin" )
			continue
		fi

		if [[ "$archive_main" -nt "$archive_main_ck_cached" ]]; then
			if [[ -d "$archive_tmp" ]]; then
				echo "Assertion failure: $archive_tmp exists" 1>&2
				exit -1
			fi

			mkdir -p "$archive_tmp"
			Tools/Archive2/Archive2.exe "$archive_main" -e="$archive_tmp" -q

			find "$archive_tmp" -type d -name "$plugin" -print0 \
				| xargs -tr0 rename "$plugin" "$plugin_ck"

			# Account for mixed case base
			for __plugin_base in "$plugin_base" \
				"$(echo "$plugin_base" | tr '[A-Z]' '[a-z]')" \
				"$(echo "$plugin_base" | tr '[a-z]' '[A-Z]')"
			do
				[[ "$__plugin_base" != "$plugin_ck_base" ]] || continue

#				find "$archive_tmp" -type d -name "$__plugin_base" -print0 \
#					| xargs -tr0 rename "$__plugin_base" "$plugin_ck_base"
				find "$archive_tmp" -type f -name "$__plugin_base*strings" -print0 \
					| xargs -tr0 rename "$__plugin_base" "$plugin_ck_base"
			done

			Tools/Archive2/Archive2.exe "$archive_tmp" -c="$archive_main_ck_tmp" -compression=None -q

			mv -t "$cdir/Data" "$archive_main_ck_tmp"
			rm -rf "$archive_tmp"
		fi
		rm -f "$cache_lock"

		if [[ "$archive_main_ck_cached" -nt "$archive_main_ck" ]]; then
			cp --remove-destination -p "$archive_main_ck_cached" "$archive_main_ck"
		fi
	done

	return 0
}

function ck_wrap() {
	set -x

	local sdir="$1"; shift
	local bdir="$1"; shift
	local odir="$1"; shift
	local cdir="$1"; shift
	local mode="$1"; shift
	local type="$1"; shift
	local area="$1"; shift
	local plugin="$1"; shift
	local cur="$1"; shift
	local max="$1"; shift
	local job="$1"; shift
	local manual="$1"; shift
	local ctl_log="$1"; shift

	# Equalized width of $cur
	local wcur=$(printf "%02d" $cur)

	set -e
	set -o pipefail

	rm -f "$bdir/$job/EditorWarnings.txt"
	trap "echo FAILURE >> '$bdir/$job/EditorWarnings.txt'; cp -p '$bdir/$job/EditorWarnings.txt' '$bdir/$plugin.$mode.$type.$area.$wcur.ck_wrap.error'" ERR

	ctl_log "$ctl_log" "$job" "$mode" "$type" "$area" "$plugin" "CLONING"

	ck_clone "$sdir" "$bdir" "$odir" "$cdir" "$mode" "$job" || exit -1

	echo -e "$sdir\t$bdir\t$odir\t$cdir\t$mode\t$type\t$area\t$plugin\t$cur\t$max\t$job\t$manual" > $bdir/$job/ck_wrap.info

	if ((!manual)); then
		# XXX: Update comment to be master specific.
		# Original plugins, can be useful in cases where masters should be
		# pulled in but not all of their extended masters (i.e. ckgen style).
		# The actual use case is rather specific in where a large amount of
		# masters are involved and handle limits are being hit in CK, which
		# prevents generation of any data.
		for i in "$bdir/$job/Data/ckgen/masters"{"","/$plugin","/$area","/$area/$plugin"}; do
			[[ -d "$i" ]] \
				&& find "$i" -maxdepth 1 -mindepth 1 -type f -print0 \
				| xargs -tr0 cp --remove-destination -pt "$bdir/$job/Data"
		done

		# Per target plugin only
		for i in "$bdir/$job/Data/ckgen"{,"/$plugin","/$area","/$area/$plugin"}; do
			[[ -f "$i/$plugin" ]] && cp --remove-destination -pt "$bdir/$job/Data" "$i/$plugin"
		done

		if [[ "$plugin" =~ .esp ]]; then
			FILE_BASE="${plugin/.esp*/.esp}.${mode}_merge"
		else
			FILE_BASE="${plugin/.esm*/.esm}.${mode}_merge"
		fi
	else
		if [[ "$plugin" =~ .esp ]]; then
			FILE_BASE="${plugin/.esp*/.esp}.${mode}_manual"
		else
			FILE_BASE="${plugin/.esm*/.esm}.${mode}_manual"
		fi
	fi

	# Ensure all plugins using esp masters (including their masters) are temporarily
	# altered to use esm masters instead.
	OIFS="$IFS"
	IFS="
"
	ESP_MASTERS=( $(plugin-master-reloc -qr --esp-only "$bdir/$job/Data/$plugin" | sort -u) )
	IFS="$OIFS"

	plugin_base="${plugin/%.es[pm]}"
	plugin_esm="${plugin/%.esp/.esm}"
	plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	plugin_ck_base="${plugin_ck/%.es[pm]}"

	if [[ "$plugin_sanitized" != "$plugin" ]]; then
		ln -f "$bdir/$job/Data/$plugin" "$bdir/$job/Data/$plugin_sanitized"
	fi

	if [[ "$plugin_esm" != "$plugin" || -n "${ESP_MASTERS[@]}" ]]; then
		# Clone plugin before modification in case it's hard linked
		cp --remove-destination -p "$bdir/$job/Data/$plugin" "$bdir/$job/Data/$plugin.$$" \
			&& mv "$bdir/$job/Data/$plugin.$$" "$bdir/$job/Data/$plugin"
		plugin-master-reloc -vfr --copy-plugin-to-esm --esp-to-esm "$bdir/$job/Data/$plugin"
	fi

	if [[ "$plugin_ck" != "$plugin" || -n "${ESP_MASTERS[@]}" ]]; then
		ctl_log "$ctl_log" "$job" "$mode" "$type" "$area" "$plugin" "REARCHIVING"

		ck_wrap_archive_rename "${ESP_MASTERS[@]}"
		if [[ "$plugin_ck" != "$plugin" ]]; then
			ck_wrap_archive_rename "$plugin"
		fi
	fi

	if ((DEBUG)); then
		CKEXEC="'/c/Program Files (x86)/Windows Kits/10/Debuggers/x64/windbg.exe' -o -pb -pr ./CreationKit.exe"
	else
		CKEXEC="./CreationKit.exe"
	fi

if false; then
	# XXX: Need to figure out just how necessary this is
	case "$mode" in
	*)
		# Generate SCOL first
		if ((!manual)); then
			CKARGS=( -generatestaticcollections:"$plugin_ck" x64 )
		fi

		if ( \
			cd "$bdir/$job" \
				&& eval "$CKEXEC" ${CKARGS[*]} \
				&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer|Unable to find masterfile' "EditorWarnings.txt" \
		);
		then
			echo "SUCCESS (generatestaticcollections)" >> "$bdir/$job/EditorWarnings.txt"
			mkdir -p "$bdir/$plugin"
			mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.generatestaticcollections.txt"
		else
			if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generatestaticcollections handles)" >> "$bdir/$job/EditorWarnings.txt"
			elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generatestaticcollections plugin)" >> "$bdir/$job/EditorWarnings.txt"
			elif fgrep -q 'Unable to find masterfile' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generatestaticcollections master)" >> "$bdir/$job/EditorWarnings.txt"
			else
				echo "FAILURE (generatestaticcollections)" >> "$bdir/$job/EditorWarnings.txt"
			fi
			cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.generatestaticcollections.error"
			exit -1
		fi

		;;
	esac
fi

	# For each given mode, nuke any old data left in per-job build
	# directory, regenerate it with CK, and then move the results
	# to the output directory.
	case "$mode" in
	precombine)
		if ((!manual)); then
			CKARGS=( -generateprecombined:"$plugin_ck" $type $area $cur $max )
		fi

		if ( \
			cd "$bdir/$job" \
				&& eval "$CKEXEC" ${CKARGS[*]} \
				&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer|Unable to find masterfile' "EditorWarnings.txt" \
		);
		then
			echo "SUCCESS (generateprecombined)" >> "$bdir/$job/EditorWarnings.txt"
			mkdir -p "$bdir/$plugin"
			mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.generateprecombined.txt"

			# XXX: Look for any newly added or modified files instead of CombinedObjects.esp specifically?
			# XXX: Might be useful for cases where manual mode is used and a different plugin is saved.
			if [[ -f "$bdir/$job/Data/CombinedObjects.esp" ]]; then
				# If run in clean mode a shared geometry psg file will be produced that
				# should be compressed with CreationKit.exe -CompressPSG:<plugin_base>.
				# A CDX file should also be produced with -BuildCDX although it's not
				# strictly necessary that the PSG file be compressed first.
				if [[ -f "$bdir/$job/Data/$plugin_ck_base - Geometry.psg" ]]; then
					# Using CombinedObjects.esp is perfectly fine as long as the requisite
					# XCRI data (which it contains), PSG or CSG file, and precombined NIFs
					# are accessible to the -BuildCDX codepath. The PSG data will be loaded
					# by one of the masters of CombinedObjects.esp and that's all the engine
					# needs (it doesn't need to explicitly match the file base). This ability
					# is highly convenient as it avoids having to copy CombinedObjects.esp to
					# a temporary file with the same file base.
					CKARGS=( -buildcdx:"CombinedObjects.esp" )
					if ( \
						cd "$bdir/$job" \
							&& eval "$CKEXEC" ${CKARGS[*]} \
							&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer|Unable to find masterfile' "EditorWarnings.txt" \
							&& mv "Data/CombinedObjects.cdx" "Data/$plugin_ck_base.cdx" \
					);
					then
						echo "SUCCESS (buildcdx)" >> "$bdir/$job/EditorWarnings.txt"
						mkdir -p "$bdir/$plugin"
						mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.buildcdx.txt"

						mkdir -p "$bdir/$plugin"
						mv "$bdir/$job/Data/$plugin_ck_base.cdx" "$bdir/$plugin/$plugin_base.cdx"
					else
						if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
							echo "FAILURE (buildcdx handles)" >> "$bdir/$job/EditorWarnings.txt"
						elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
							echo "FAILURE (buildcdx plugin)" >> "$bdir/$job/EditorWarnings.txt"
						elif fgrep -q 'Unable to find masterfile' "$bdir/$job/EditorWarnings.txt"; then
							echo "FAILURE (buildcdx master)" >> "$bdir/$job/EditorWarnings.txt"
						else
							echo "FAILURE (buildcdx)" >> "$bdir/$job/EditorWarnings.txt"
						fi
						cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.buildcdx.error"

						# It's not strictly critical that a cdx file is built - it's only critical that
						# if it exists *and* if CSG/PSG precombines are used that it's kept up to date.
						# exit -1
					fi

					CKARGS=( -compresspsg:"$plugin_ck" )
					if ( \
						cd "$bdir/$job" \
							&& eval "$CKEXEC" ${CKARGS[*]} \
							&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer|Unable to find masterfile' "EditorWarnings.txt" \
					);
					then
						echo "SUCCESS (compresspsg)" >> "$bdir/$job/EditorWarnings.txt"
						mkdir -p "$bdir/$plugin"
						mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.compresspsg.txt"

						# -BuildCDX depends on these files and the emitted plugin to generate accurate data. As such
						# they should be moved after both -CompressPSG and -BuildCDX are finished.
						mkdir -p "$bdir/$plugin"
						mv "$bdir/$job/Data/$plugin_ck_base - Geometry.csg" "$bdir/$plugin/$plugin_base - Geometry.csg"
						mv "$bdir/$job/Data/$plugin_ck_base - Geometry.psg" "$bdir/$plugin/$plugin_base - Geometry.psg"
					else
						if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
							echo "FAILURE (compresspsg handles)" >> "$bdir/$job/EditorWarnings.txt"
						elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
							echo "FAILURE (compresspsg plugin)" >> "$bdir/$job/EditorWarnings.txt"
						elif fgrep -q 'Unable to find masterfile' "$bdir/$job/EditorWarnings.txt"; then
							echo "FAILURE (compresspsg master)" >> "$bdir/$job/EditorWarnings.txt"
						else
							echo "FAILURE (compresspsg)" >> "$bdir/$job/EditorWarnings.txt"
						fi
						cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.compresspsg.error"
						exit -1
					fi
				fi

				CKARGS=( -dumpneededfiles:"CombinedObjects.esp" "dumpneededfiles.out" )
				if ( \
					cd "$bdir/$job" \
						&& eval "$CKEXEC" ${CKARGS[*]} \
						&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer|Unable to find masterfile' "EditorWarnings.txt" \
				);
				then
					echo "SUCCESS (dumpneededfiles)" >> "$bdir/$job/EditorWarnings.txt"
					mkdir -p "$bdir/$plugin"
					mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.dumpneeded.txt"

					cat "$bdir/$job/dumpneededfiles.out" \
						| sed -e "s#CombinedObjects.esp#$plugin#g" \
						| tr -d '[\r\0\031]' | tr '\\' '/' \
						> "$bdir/$job/dumpneededfiles.out.cleaned"

					# If the plugin was copied to an esm or sanitized, change any references in dumpneeded.out
					if [[ "$plugin_ck" != "$plugin" ]]; then
						sed -i -e "s#$plugin_ck#$plugin#g" "$bdir/$job/dumpneededfiles.out.cleaned"
					fi

					mkdir -p "$bdir/$plugin"
					mv "$bdir/$job/dumpneededfiles.out.cleaned" "$bdir/$plugin/$FILE_BASE.$area.$wcur.needed.out" || true
				else
					if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
						echo "FAILURE (dumpneededfiles handles)" >> "$bdir/$job/EditorWarnings.txt"
					elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
						echo "FAILURE (dumpneededfiles plugin)" >> "$bdir/$job/EditorWarnings.txt"
					elif fgrep -q 'Unable to find masterfile' "$bdir/$job/EditorWarnings.txt"; then
						echo "FAILURE (dumpneededfiles master)" >> "$bdir/$job/EditorWarnings.txt"
					else
						echo "FAILURE (dumpneededfiles)" >> "$bdir/$job/EditorWarnings.txt"
					fi
					cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.dumpneeded.error"
					exit -1
				fi

				# If the plugin was copied to an esm, switch esm masters back to esp masters
				if [[ "$plugin_ck" != "$plugin" ]]; then
					plugin-master-reloc -vfr --esm-to-esp --sub "$plugin_ck_base:$plugin_base" "$bdir/$job/Data/CombinedObjects.esp"
				fi

				mkdir -p "$bdir/$plugin"
				mv "$bdir/$job/Data/CombinedObjects.esp" "$bdir/$plugin/$FILE_BASE.$area.$wcur.esp"
			fi

			if [[ -d "$bdir/$job/Data/Meshes/PreCombined" ]]; then
				# If plugin name has been sanitized or flipped to an esm, change any
				# directory references back to the original plugin name.
				if [[ "$plugin_ck" != "$plugin" ]]; then
					find "$bdir/$job/Data/Meshes/PreCombined" -type d -name "$plugin_ck" -print0 \
						| xargs -tr0 rename "$plugin_ck" "$plugin"
				fi

				# If there are any esp masters which were changed to esm masters in the
				# plugin, change any directory references back to their esp form.
				for esp in "${ESP_MASTERS[@]}"; do
					esm="${esp/%.esp/.esm}"
					find "$bdir/$job/Data/Meshes/PreCombined" -type d -name "$esm" -print0 \
						| xargs -tr0 rename "$esm" "$esp"
				done

				mkdir -p "$bdir/$plugin"
				mv "$bdir/$job/Data/Meshes/PreCombined" "$bdir/$plugin/PreCombined.$area.$wcur"
			fi

		else
			if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generateprecombined handles)" >> "$bdir/$job/EditorWarnings.txt"
			elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generateprecombined plugin)" >> "$bdir/$job/EditorWarnings.txt"
			elif fgrep -q 'Unable to find masterfile' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generateprecombined master)" >> "$bdir/$job/EditorWarnings.txt"
			else
				echo "FAILURE (generateprecombined)" >> "$bdir/$job/EditorWarnings.txt"
			fi
			cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.generateprecombined.error"
			exit -1
		fi

		;;

	previs)
		if ((!manual)); then
			CKARGS=( -generateprevisdata:"$plugin_ck" $type $area $cur $max )
		fi

		if ( \
			cd "$bdir/$job" \
				&& eval "$CKEXEC" ${CKARGS[*]} \
				&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer' "EditorWarnings.txt" \
		);
		then
			echo "SUCCESS (generateprevisdata)" >> "$bdir/$job/EditorWarnings.txt"
			mkdir -p "$bdir/$plugin"
			mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.generateprevisdata.txt"

			# XXX: Look for any newly added or modified files instead of CombinedObjects.esp specifically?
			# XXX: Might be useful for cases where manual mode is used and a different plugin is saved.
			if [[ -f "$bdir/$job/Data/PreVis.esp" ]]; then
				CKARGS=( -dumpneededfiles:"PreVis.esp" "dumpneededfiles.out" )
				if ( \
					cd "$bdir/$job" \
						&& eval "$CKEXEC" ${CKARGS[*]} \
						&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer' "EditorWarnings.txt" \
				);
				then
					echo "SUCCESS (dumpneededfiles)" >> "$bdir/$job/EditorWarnings.txt"
					mkdir -p "$bdir/$plugin"
					mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.dumpneeded.txt"

					cat "$bdir/$job/dumpneededfiles.out" \
						| sed -e "s#PreVis.esp#$plugin#g" \
						| tr -d '[\r\0\031]' | tr '\\' '/' \
						> "$bdir/$job/dumpneededfiles.out.cleaned"

					# If the plugin was copied to an esm or sanitized, change any references in dumpneeded.out
					if [[ "$plugin_ck" != "$plugin" ]]; then
						sed -i -e "s#$plugin_ck#$plugin#g" "$bdir/$job/dumpneededfiles.out.cleaned"
					fi

					mkdir -p "$bdir/$plugin"
					mv "$bdir/$job/dumpneededfiles.out.cleaned" "$bdir/$plugin/$FILE_BASE.$area.$wcur.needed.out" || true
				else
					if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
						echo "FAILURE (dumpneededfiles handles)" >> "$bdir/$job/EditorWarnings.txt"
					elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
						echo "FAILURE (dumpneededfiles file)" >> "$bdir/$job/EditorWarnings.txt"
					else
						echo "FAILURE (dumpneededfiles)" >> "$bdir/$job/EditorWarnings.txt"
					fi
					cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.dumpneeded.error"
					exit -1
				fi

				# If the plugin was copied to an esm, switch esm masters back to esp masters
				if [[ "$plugin_ck" != "$plugin" ]]; then
					plugin-master-reloc -vfr --esm-to-esp --sub "$plugin_ck_base:$plugin_base" "$bdir/$job/Data/PreVis.esp"
				fi

				mkdir -p "$bdir/$plugin"
				mv "$bdir/$job/Data/PreVis.esp" "$bdir/$plugin/$FILE_BASE.$area.$wcur.esp"
			fi

			if [[ -d "$bdir/$job/Data/Vis" ]]; then
				# If plugin name has been sanitized or flipped to an esm, change any
				# directory references back to the original plugin name.
				if [[ "$plugin_ck" != "$plugin" ]]; then
					find "$bdir/$job/Data/Vis" -type d -name "$plugin_ck" -print0 \
						| xargs -tr0 rename "$plugin_ck" "$plugin"
				fi

				# If there are any esp masters which were changed to esm masters in the
				# plugin, change any directory references back to their esp form.
				for esp in "${ESP_MASTERS[@]}"; do
					esm="${esp/%.esp/.esm}"
					find "$bdir/$job/Data/Vis" -type d -name "$esm" -print0 \
						| xargs -tr0 rename "$esm" "$esp"
				done

				mkdir -p "$bdir/$plugin"
				mv "$bdir/$job/Data/Vis" "$bdir/$plugin/Vis.$area.$wcur"
			fi
		else
			if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generateprevisdata handles)" >> "$bdir/$job/EditorWarnings.txt"
			elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (generateprevisdata file)" >> "$bdir/$job/EditorWarnings.txt"
			else
				echo "FAILURE (generateprevisdata)" >> "$bdir/$job/EditorWarnings.txt"
			fi
			cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.generateprevisdata.error"
			exit -1
		fi

		;;

	needed)
		if ((!manual)); then
			CKARGS=( -dumpneededfiles:"$plugin_ck" "dumpneededfiles.out" )
		fi
		if ( \
			cd "$bdir/$job" \
				&& eval "$CKEXEC" ${CKARGS[*]} \
				&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer' "EditorWarnings.txt" \
		);
		then
			echo "SUCCESS (dumpneededfiles)" >> "$bdir/$job/EditorWarnings.txt"
			mkdir -p "$bdir/$plugin"
			mv "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$area.$wcur.dumpneeded.txt"

			cat "$bdir/$job/dumpneededfiles.out" \
				| tr -d '[\r\0\031]' | tr '\\' '/' \
				> "$bdir/$job/dumpneededfiles.out.cleaned"

			# If the plugin was copied to an esm or sanitized, change any references in dumpneeded.out
			if [[ "$plugin_ck" != "$plugin" ]]; then
				sed -i -e "s#$plugin_ck#$plugin#g" "$bdir/$job/dumpneededfiles.out.cleaned"
			fi

			mkdir -p "$bdir/$plugin"
			mv "$bdir/$job/dumpneededfiles.out.cleaned" "$bdir/$plugin/$FILE_BASE.$area.$wcur.needed.out"
		else
			if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (dumpneededfiles handles)" >> "$bdir/$job/EditorWarnings.txt"
			elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
				echo "FAILURE (dumpneededfiles file)" >> "$bdir/$job/EditorWarnings.txt"
			else
				echo "FAILURE (dumpneededfiles)" >> "$bdir/$job/EditorWarnings.txt"
			fi
			cp -p "$bdir/$job/EditorWarnings.txt" "$bdir/$FILE_BASE.$area.$wcur.dumpneeded.error"
			exit -1
		fi

		;;
	esac

	# XXX: Only on error?
	# Copy plugin used for generation for reference purposes
	if [[ -n "$plugin" && -f "$bdir/$job/Data/$plugin" ]]; then
		mkdir -p "$bdir/$plugin"
		cp -p "$bdir/$job/Data/$plugin" "$bdir/$plugin/$plugin.$mode.$area"
	fi

	echo "SUCCESS" >> "$bdir/$job/EditorWarnings.txt"

	return 0
}

function ck_log_wrap() {
	local build="$1"; shift
	local wrap_mode="$1"; shift
	local jobs="$1"; shift

	set -e
	set -o pipefail

	# Precompute filenames rather than rely on shell globbing as they're usually
	# non-existent when tail starts (and tail -F handles that issue on it's own).
	local -a logs=( "$build/tmp/ctl.log" $(printf "$build/%s/EditorWarnings.txt " $(seq -s ' ' 1 $jobs)) )

	echo $$ > "$build/tmp/ck_log_wrap.$wrap_mode.pid"

	tail -vn0 -s 0.1 -F "${logs[@]}" 2>/dev/null \
		| LC_ALL=C awk \
			-v wrap_mode="$wrap_mode" \
			-v ctl_log="$build/tmp/ctl.log" \
			-v build_dir="$build" \
			-v info_file="ck_wrap.info" '
	BEGIN{
		IGNORECASE=1
	}
	{
		if (!length) {
			next;
		} else if ($0 ~ /^==> /) {
			if (match($0, "^==> .+/([0-9]+)/.+ <==$", a)) {
				id_cur=a[1];
				f = sprintf("%s/%d/%s", build_dir, id_cur, info_file);
				while (getline < f > 0) {
					split($0, info, "\t");
				}
				close(f);
				mode=info[5];
				type=info[6];
				area=info[7];
				plugin=info[8];
				ctl=0
			} else if ($0 ~ ctl_log) {
				ctl=1
			}
			next;
		} else if (wrap_mode == "cell") {
			if (ctl) {
				split($0, info, "\t");
				id_cur=info[1];
				mode=info[2];
				type=info[3];
				area=info[4];
				plugin=info[5];
				$0=info[6];
				usepcnt=0;
			} else {
				if ($0 !~ /generat.*for.*cell|Number of registered paths|SUCCESS|FAILURE/)
					next;
#				if ($0 ~ /SUCCESS \(.+\)/)
#					next;
				if ($0 ~ /ROOTCELL/)
					next;
				if ($0 ~ /SUCCESS|FAILURE/)
					usepcnt=0;
				else
					usepcnt=1;
			}
		} else if (wrap_mode == "all") {
			if (ctl)
				next;
			if ($0 ~ /gen.*for.*cell/)
				next;
			usepcnt=1;
		} else {
			next;
		}

		if (usepcnt)
			printf("%8d %32.32s %12s %8s %8s [%d] %8d %s\n", ++cnt, plugin, mode, type, area, id_cur, ++cnttab[plugin], $0);
		else
			printf("%8d %32.32s %12s %8s %8s [%d] %8s %s\n", ++cnt, plugin, mode, type, area, id_cur, "", $0);
	}'

	return 0
}

if [[ "$1" == "--wrap" ]]; then
	shift; ck_wrap "$@"
	exit $?
elif [[ "$1" == "--log-wrap" ]]; then
	shift; ck_log_wrap "$@"
	exit $?
fi

TMUX=1
SHARDS=1
SHARDS_START=1
CORES=$(cpu_core_cnt)
THREADS=$(cpu_thread_cnt)
JOBS=$CORES
SELF=$(basename $0)
CACHE=$SELF.cache
BUILD=$SELF.build
OUT=$SELF.out
TYPE="filtered"
AREA="main"
PRESERVE_CACHE=1
PRESERVE_BUILD=0
PRESERVE_OUT=0
MANUAL=0

# XXX: Use -c for cache option?
while getopts "j:s:S:t:A:PpamMg" opt; do
        case $opt in
	j) JOBS="$OPTARG" ;;
	s) SHARDS="$OPTARG" ;;
	S) SHARDS_START="$OPTARG" ;;
	t) TMUX="$OPTARG" ;;
	A) ARCHIVE="$OPTARG" ;;
	p) PRESERVE_OUT=1 ;;
	P) PRESERVE_OUT=1; PRESERVE_BUILD=1 ;;
	a) ARCHIVE=1 ;;
	m) MERGE=1 ;;
	M) MANUAL=1 ;;
	g) DEBUG=1 ;;
	?) exit -1 ;;
        esac
done; shift $((OPTIND - 1))

PROFILE="$1"; shift
if [[ -z "$PROFILE" ]]; then
	echo "No profile specified" 1>&2
	exit -1
elif [[ ! -d "$PROGDIR/Fallout 4.$PROFILE" ]]; then
	echo "$PROGDIR/Fallout 4.$PROFILE does not exist" 1>&2
	exit -1
fi

MODE="$1"; shift

# XXX: buildcdx, checkinplugin, generatescol?
# Could not parse command line properly.  Should be -GeneratePreCombined:<ESMFilename> [clean,filtered] [all,main,ints,other] [currentset(1-totalsetcount)] [totalsetcount]
# Could not parse command line properly.  Should be -GeneratePreVisData:<ESMFilename> [clean,filtered] [all,main,ints,other] [currentset(1-totalsetcount)] [totalsetcount]
case "$MODE" in
needed)
	SHARDS=1
	SHARDS_FORCE=1
	;;
precombine|previs)
	if ((!MANUAL)); then
		TYPE="$1"; shift
		AREA="$1"; shift
	elif [[ "$1" == "clean" || "$1" == "filtered" ]]; then
		case "$2" in
		ALL|all|main|other|ints) shift; shift ;;
		esac
	fi

	if [[ "$TYPE" != "clean" && "$TYPE" != "filtered" ]]; then
		echo "Invalid type: $TYPE" 1>&2
		exit -1
	fi

	AREA=( ${AREA//,/ } )
	for area in ${AREA[*]}; do
		if [[ "$area" == "ALL" ]]; then
			AREA=( main ints other )
			continue
		elif [[ "$area" != "all" && "$area" != "main" && "$area" != "ints" && "$area" != "other" ]]; then
			echo "Invalid area: $area" 1>&2
			exit -1
		fi
	done
	;;
*)
	echo "Invalid mode: $MODE" 1>&2
	exit -1
	;;
esac

JOBS_TOTAL=0
PLUGIN=( "$@" )
for plugin in "${PLUGIN[@]}"; do
	plugin_parse "$plugin" plugin t a s

	[[ -n $a ]] && atmp=( ${a//,/ } ) || atmp=( ${AREA[*]} )
	[[ -n $t ]] || t=$TYPE
	[[ -n $s ]] && s=$((SHARDS_FORCE ? SHARDS : s)) || s=$SHARDS

	for area in ${atmp[*]}; do
#		if [[ "$area" != "all" && "$MODE" == "precombine" && "$t" == "clean" ]] || [[ "$t" == "clean" && $s -ne 1 ]]; then
		if [[ "$MODE" == "precombine" && "$t" == "clean" && $s -ne 1 ]]; then
			echo "$plugin: Error: generating precombines of type 'clean' cannot be run in parallel or in sub-areas due to inability to merge shared geometry data (PSG/CSG)" 1>&2
			exit -1
#			elif [[ "$area" != "main" && "$area" != "ints" && $s -ne 1 ]]; then
#				echo "$plugin: Warning: area of '$area' does not parallelize (CK limitation)" 1>&2
#				s=1
		fi

		for j in $(seq -s ' ' $SHARDS_START $s); do
			let ++JOBS_TOTAL
		done
	done
done

SRC="$PROGDIR/Fallout 4.$PROFILE"
cd "$SRC"

# XXX: Completely rewrite this, and preferably use a function
# Must occur before build dir clone as it's dependent on any cached files
if ((!PRESERVE_CACHE)) || [[ ! -d "$CACHE" ]]; then
	echo "Removing cache..." 1>&2
	rm -rf "$CACHE" && mkdir -p "$CACHE" "$CACHE/Data" "$CACHE/tmp" || exit -1

	case "$MODE" in
	previs)
		# XXX: Update comment to be accurate
		# Special hack for Fallout4.esm due to limitations in CK
		# around the maximum number of cached file handles involved
		# with loose files. Since Data/Meshes/PreCombined usually
		# contains over 100k files for a full generation an archive
		# needs to be used for precombines (via CreationKit.ini).
		# However, since loose files override archives, the actual
		# directory needs to be moved aside so CreationKit doesn't
		# parse the loose files.
		for plugin in "${PLUGIN[@]}"; do
			plugin_parse "$plugin" plugin t a s

			# XXX: cleanup
			(
			for i in Main MeshesExtra; do
				b="${plugin/.es[mp]} - $i.ba2"
				if [[ -f "Data/$b" ]]; then
					BASE_BA2="$b"
					break
				fi
			done

			# XXX: What if it was never precombined before? This will fail but an
			# XXX: archive should be created.
			#
			# XXX: What about loose files? In that case the loose precombined or
			# XXX: loose previs data files need to be ignored or removed somehow
			# XXX: or else they'll take precedence. The latter is taken care of
			# XXX: by the initial build area rsync, but the runtime finalized
			# XXX: state would still have an issue if the loose files were around.
			[[ -n "$BASE_BA2" ]] || continue

			DATA_BA2="Data/$BASE_BA2"
			CKGEN_BA2="$CACHE/Data/$BASE_BA2"

# XXX: This needs to work better with PRESERVE_CACHE
#			# Check mtime of vanilla archives / loose files
#			if [[ -f "$CKGEN_BA2" ]] && ! find "Data/Meshes/PreCombined" "$DATA_BA2" -newer "$CKGEN_BA2" | grep -q ''; then
#				echo "$plugin: Using cached '$BASE_BA2'" 1>&2
#				continue
#			fi

			# Get the latest needed.out file if available
			PC_NEEDED=$(ls -t {Data,.}/$plugin.{precombine*merge*needed.out,needed.out} 2>/dev/null | head -1 || true)
			[[ -n "$PC_NEEDED" ]] || continue

			echo "$plugin: Repackaging temporary '$BASE_BA2' with updated precombines..." 1>&2
			mkdir -p "$CACHE/tmp/$plugin"
			Tools/Archive2/Archive2.exe "$DATA_BA2" -e="$CACHE/tmp/$plugin/Data" -q

			# XXX: Cleanup into 1 awk?
			(
				awk -v sd='Data' '/(PreCombined|Vis)\//{ printf("%s/%s\0", sd, $NF) }' "$PC_NEEDED" | xargs -r0 find 2>/dev/null || true
				find "$CACHE/tmp/$plugin" -type f
			) | tee "$CACHE/tmp/$plugin.archive.list.pre" | awk '{ s=gensub("^.*Data/", "", 1); if (!stab[s]++) print $0 }' > "$CACHE/tmp/$plugin.archive.list"

			LIST_CNT=$(wc -l < "$CACHE/tmp/$plugin.archive.list")
			LIST_WIN=$(cygpath -aw "$CACHE/tmp/$plugin.archive.list")

			Tools/Archive2/Archive2.exe -s="$LIST_WIN" -c="$CKGEN_BA2" 2>&1 \
				| tee "$CACHE/tmp/archive.$plugin.$LIST_CNT.out" \
				| awk -v cnt="$LIST_CNT" '/^(Adding|Skipped non-existing)/{ ++i; printf("\r%s / %s (%0.2f%%)", i, cnt, i * 100 / cnt) }END{ printf("\n") }'
			rm -rf "$CACHE/tmp/$plugin"

			# XXX: Store generated archives in src Data or ckgen.cache?
			) &
		done; wait
		;;
	esac
fi

if ((!PRESERVE_BUILD)) || [[ ! -d "$BUILD" ]]; then
	echo "Removing previous build data..." 1>&2
	rm -rf "$BUILD" && mkdir -p "$BUILD" || exit -1
fi

if ((!PRESERVE_OUT)) || [[ ! -d "$OUT" ]]; then
	echo "Removing previous output data..." 1>&2
	rm -rf "$OUT" && mkdir -p "$OUT" || exit -1
fi

# Cleanup any temporary files from prior runs
rm -rf "$BUILD/tmp" && mkdir -p "$BUILD/tmp"
rm -rf "$CACHE/tmp" && mkdir -p "$CACHE/tmp"

# Generate output file of jobs to be run by parallel
for plugin in "${PLUGIN[@]}"; do
	plugin_parse "$plugin" plugin t a s

	[[ -n $a ]] && atmp=( ${a//,/ } ) || atmp=( ${AREA[*]} )
	[[ -n $t ]] || t=$TYPE
	[[ -n $s ]] && s=$((SHARDS_FORCE ? SHARDS : s)) || s=$SHARDS

	for area in ${atmp[*]}; do
		# Use tabs for arg separation and escape-quote $plugin so that when parallel
		# interprets this input line to call ck_wrap it doesn't consume quotes.
		for _s in $(seq -s ' ' $SHARDS_START $s); do
			printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$SRC" "$BUILD" "$OUT" "$CACHE" "$MODE" "$t" "$area" "$plugin" "$_s" "$s"
		done
	done
done > "$BUILD/tmp/jobs.in"

if ((MANUAL)); then
	PFLAGS="--res $BUILD/tmp/{6}/{7}/{8}/{9}/{10}/{11}/ --joblog=$BUILD/tmp/jobs.log --progress --delay 2 --lb -tr -j $JOBS --colsep '\t'"
else
	PFLAGS="--res $BUILD/tmp/{6}/{7}/{8}/{9}/{10}/{11}/ --joblog=$BUILD/tmp/jobs.log --eta --shuf --lb -tr -j $JOBS --colsep '\t'"
fi

# Note: final 'read' commands are to prevent tmux from closing each sub-window
if ((TMUX)); then
	# Final command to execute after parallel finishes
	PAUSE="read"

	# tmux doesn't emit the exit status of child commands as part of it's own exit status
	rm -f "$BUILD/tmp/parallel.error"
	tmux new \
		"ckgen --log-wrap '$BUILD' cell $JOBS" ';' \
		split -p 40 \
		"ckgen --log-wrap '$BUILD' all $JOBS" ';' \
		split -p 50 \
		"parallel $PFLAGS 'ckgen --wrap {} {%} $MANUAL $BUILD/tmp/ctl.log' < '$BUILD/tmp/jobs.in'; [[ \$? -ne 255 ]] && $PAUSE || touch '$BUILD/tmp/parallel.error'; cat '$BUILD/tmp/ck_log_wrap'.*.pid | xargs -r kill" ';' \
		set-option status off \
		&& [[ ! -f "$BUILD/tmp/parallel.error" ]] \
		|| exit -1
else
	parallel $PFLAGS "ckgen --wrap {} {%} $MANUAL $BUILD/tmp/ctl.log" < "$BUILD/tmp/jobs.in" || exit -1
fi

# Process output from build
for plugin in "${PLUGIN[@]}"; do
	plugin_parse "$plugin" plugin t a s

	if [[ -d "$BUILD/$plugin" ]]; then
		# XXX: this is a mv which could affect a previs after a precombine if an archive isn't involved inbetween
		if ls -d "$BUILD/$plugin/PreCombined".* &>/dev/null; then
			echo "$plugin: Moving precombined..." 1>&2

			mkdir -p "$OUT/$plugin/Data/Meshes/PreCombined"
			ls -d "$BUILD/$plugin/PreCombined".* | while read tmp; do
				rsync --protect-args -aS --link-dest="$PWD/$tmp" "$tmp"/ "$OUT/$plugin/Data/Meshes/PreCombined"/ || true
				rmdir --ignore-fail-on-non-empty "$tmp" || true
			done
		fi

		if ls -d "$BUILD/$plugin/Vis".* &>/dev/null; then
			echo "$plugin: Moving previs..." 1>&2

			mkdir -p "$OUT/$plugin/Data/Vis"
			ls -d "$BUILD/$plugin/Vis".* | while read tmp; do
				rsync --protect-args -aS --link-dest="$PWD/$tmp" "$tmp"/ "$OUT/$plugin/Data/Vis"/ || true
				rmdir --ignore-fail-on-non-empty "$tmp" || true
			done
		fi

		if ls -d "$BUILD/$plugin"/*.[pc]sg &>/dev/null; then
			echo "$plugin: Moving shared geometry..." 1>&2

			mkdir -p "$OUT/$plugin/Data"
			mv -t "$OUT/$plugin/Data" "$BUILD/$plugin/"*.[pc]sg || true
		fi

		if ls -d "$BUILD/$plugin"/*.cdx &>/dev/null; then
			echo "$plugin: Moving cell resource index..." 1>&2

			mkdir -p "$OUT/$plugin/Data"
			mv -t "$OUT/$plugin/Data" "$BUILD/$plugin/"*.cdx || true
		fi

		# XXX: Fix
		if ls -d "$BUILD/$plugin/$plugin".*.{all,main,ints,other} &>/dev/null; then
			echo "$plugin: Moving reference plugins..." 1>&2

			mkdir -p "$OUT/$plugin"
			mv -t "$OUT/$plugin" "$BUILD/$plugin/$plugin".*.{all,main,ints,other} || true
		fi

		if ls -d "$BUILD/$plugin/"*.esp &>/dev/null; then
			echo "$plugin: Moving generated plugins..." 1>&2

			mkdir -p "$OUT/$plugin/Data"
			mv -t "$OUT/$plugin/Data" "$BUILD/$plugin/"*.esp || true
		fi

		if ls -d "$BUILD/$plugin/"*.needed*out &>/dev/null; then
			echo "$plugin: Moving needed files output..." 1>&2

			mkdir -p "$OUT/$plugin/Data"
			mv -t "$OUT/$plugin" "$BUILD/$plugin/"*.needed*out || true
		fi

		if ls -d "$BUILD/$plugin"/EditorWarnings*.txt &>/dev/null; then
			echo "$plugin: Moving editor warnings output..." 1>&2

			mkdir -p "$OUT/$plugin"
			mv -t "$OUT/$plugin" "$BUILD/$plugin"/EditorWarnings*.txt || true
		fi
	fi

	if ls -d "$BUILD/$plugin".*.error &>/dev/null; then
		echo "$plugin: Moving error output..." 1>&2

		mkdir -p "$OUT"
		mv -t "$OUT" "$BUILD/$plugin".*.error || true
	fi

	# XXX: hardlink plugins into Data?
	if false && ((MERGE)); then
		echo "$plugin: Merging plugins..." 1>&2

		# XXX: Plugins might have to be in Data first
		# Could not parse command line properly.  Should be -CheckInPlugin:<PluginFilename> <ESMFilename>
		find "$OUT/$plugin" -type f -name '*.esp' -print0 \
			| xargs -I{} -tr0 -n1 ./CreationKit.exe -checkinplugin:{} $plugin
	fi

	# XXX: hardlink archive into Data?
	# XXX: Make sure filenames are compatible with vanilla and/or reexamine if this should
	# XXX: just create a single archive from all ESMs
	if false && ((ARCHIVE)); then
		echo "$plugin: Archiving data..." 1>&2

		# Output data will contain precombined and/or previs data only at this point
		Tools/Archive2/Archive2.exe "$OUT/$plugin/Data" -c="$OUT/$plugin/${plugin/.es[pm]} - ckgen.ba2"
	fi

done
