#!/bin/bash

set -e
#set -o pipefail

source "$HOME/git/fo4tools/etc/fo4tools.conf" || source /usr/local/etc/fo4tools.conf

# Prereq check
for i in tmux rsync parallel lockfile; do
	if ! which $i &>/dev/null; then
		echo "$i not found" 1>&2
		exit -1
	fi
done

function cpu_core_cnt() {
	awk '/cpu cores/ && !seen[$NF]++ { print $NF }' /proc/cpuinfo
}

function cpu_thread_cnt() {
	egrep -c '^processor[[:space:]]+' /proc/cpuinfo
}

# XXX: Handle plugin:area/<shards>,area/<shards> *and* plugin/shards
function plugin_parse() {
	local tmp _p _t _a _s

	# Thankfully this "grammar" is unambiguous enough..
	OIFS="$IFS"
	IFS=":"
	tmp=( ${1%%/[0-9]} )
	_p=$(basename "${tmp[0]}")
	IFS="/:,"
	tmp=( ${1/${tmp[0]}} )
	IFS="$OIFS"

	for i in ${tmp[*]}; do
		# plugin:clean:ints,other/2 (clean ints,other 2)
		# plugin:clean:ints (clean ints SHARDS)
		# plugin:clean/2 (clean all 2)
		# plugin:ints/4 (TYPE ints 4)
		# plugin:clean (clean AREA SHARDS)
		# plugin:ints (TYPE ints SHARDS)
		# plugin/4 (TYPE AREA 4)
		case "$i" in
		filtered|clean) _t="$i" ;;
		ALL@*|all@*|main@*|ints@*|other@*|ALL|all|main|ints|other) _a="${_a:+$_a,}$i" ;;
		[0-9]*) _s="$i" ;;
		*) echo "Unknown option: $i" 1>&2; exit -1 ;;
		esac
	done

	# Bash really sucks for this type of thing
	eval "$2=\"$_p\"; $3=\"$_t\"; $4=\"$_a\"; $5=\"$_s\""
}

function ctl_log() {
	echo -e "$2\t$3\t$4\t$5\t$6\t$7\t$8" >> "$1"
}

function ck_ini_rewrite() {
	# Enable multiple instances (so multiple copies can be run in parallel).
	# Disable version control (so inability to check out a cell isn't an issue).
	# Disable stopping on "important" warnings (so combined data warnings don't stop previs generation).
	# Keep plugins that are merged with -checkinplugin (otherwise records merged and removed from the plugin).
	# Force a few other previs related settings explicitly (even though they're the same as default).
	# Force sFile Path to point to the build directory (precautionary as CK will use the cwd by default).
	# Set umbra threads to core count (default is 4).
	#
	# iMaxUmbraBakeThreads=8
	# bExportSceneOnUmbraGenerate=0
	# bExportTomeOnUmbraGenerate=0
	# bGeneratePreCombinedGeometryPreVis=1
	# bKeepPluginWhenMerging=1
	# bHideImportantWarnings=1
	# bUseVersionControl=0
	#
	# Other keys:
	# uDefaultCombinedObjectLevelsXY:General
	# uDefaultCombinedObjectLevelsZ:General
	# bCombinedObjectsAvailableForPicking:Display
	# bOnlyLoadPreVis3D:General
	# bOnlyLoadCombinable3D:General
	# fPreVisCameraBufferNear:General
	# fPreVisCameraZShift:General
	# bDoMultithreadedVisQuery:General
	# bUsePreCulledObjects:Display
	# bPreCulledObjectsEnabled:General
	# bAllowResourceReloading:General
	# bUsePreCreatedSCOL:General

	local bdir="$1"; shift
	local job="$1"; shift

	set -e
	set -o pipefail

	local wpwd=$(cygpath -aw "$bdir/$job/")
	awk -v threads=$(cpu_thread_cnt) -v wpwd="${wpwd//\\/\\\\}\\\\" '
	{
		if (match($0, "^\\[([^\\]]+)\\]", a)) {
			section=a[1];
			slist[++slidx]=section;
		} else if ($0 !~ /^$/ && match($0, "^([^=;]+) ?= ?([^\r\n]+)[\r\n]?$", a)) {
			shash[section][a[1]]=a[2];
		}
	}END{
#		shash["Memory"]["bEnableMemoryTracking"]=1;
#		shash["General"]["bChangingLotsOfBaseObjects"]=1;
#		shash["General"]["bAllowClearOldestBufferedExterior"]=1;
#		shash["General"]["bMinimizeCachedExteriors"]=1;
#		shash["General"]["bPreemptivelyUnloadCells"]=1;
#		shash["General"]["bOnlyQueueCellsWhenRefsLoaded"]=1;
#		shash["General"]["bOutputCombinedGeomDataWhenTinting"]=1;
#		shash["General"]["bForcePreCombinedObject32bitExport"]=0;
#		shash["General"]["bCheckDLCCombinedKeys"]=0;
#		shash["General"]["bFixDLCCombinedKeys"]=0;
#		shash["General"]["bOnlyLoadCombinable3D"]=1;
#		shash["General"]["bOnlyLoadPreVis3D"]=1;
#		shash["General"]["bUseCombinedObjects"]=1;
#		shash["General"]["bUsePreCulledObjects"]=1;
#		shash["General"]["bCleanUpInvalidFormsOnLoad"]=0;
#		shash["General"]["bFixAIPackagesOnLoad"]=0;
#		shash["DistantLOD"]["bUpdateDistantRefDataOnLoad"]=1;
		shash["General"]["bGeneratePreCombinedGeometryPreVis"]=1;
		shash["General"]["bExportSceneOnUmbraGenerate"]=0;
		shash["General"]["bExportTomeOnUmbraGenerate"]=0;
		shash["General"]["iMaxUmbraBakeThreads"]=threads;
		shash["General"]["bSkipValidateForms"]=1;
		shash["General"]["bSkipValidateInfos"]=1;
		shash["General"]["bSkipProgramFlows"]=1;
		shash["General"]["bSkipInitializationFlows"]=1;
		shash["General"]["bThrowProcessCompleteExceptions"]=0;
		shash["General"]["iNumHWThreads"]=threads;
		shash["General"]["iMaxJobThreads"]=threads;
		shash["General"]["bKeepPluginWhenMerging"]=1;
		shash["General"]["bHideImportantWarnings"]=1;
		shash["General"]["bAllowMultipleEditors"]=1;
		shash["General"]["bAllowMultipleMasterLoads"]=1;
		shash["General"]["bLoadTheUserPlugin"]=0;
		shash["General"]["bUseVersionControl"]=0;
		shash["General"]["bBackgroundLoading"]=1;
		shash["Pathfinding"]["bFixNavmeshInfosOnLoad"]=0;
		shash["BackgroundLoad"]["bBackgroundCellLoads"]=1;
		shash["BackgroundLoad"]["bUseBackgroundFileLoader"]=1;
		shash["Archive"]["bInvalidateOlderFiles"]=1;
		shash["Archive"]["sResourceDataDirsFinal"]="";
		shash["Audio"]["bEnableAudio"]=0;
		shash["General"]["sFile Path"]=wpwd;

		for (i = 1; i <= slidx; i++) {
			section=slist[i];
			printf("%s[%s]\r\n", i > 1 ? "\r\n" : "", section);

			if (!length(shash[section]))
				continue;
			asorti(shash[section], ss_src);

			for (j = 1; j <= length(ss_src); j++) {
				hk = ss_src[j];
				printf("%s=%s\r\n", hk, shash[section][hk]);
			}
		}
	}'
}

function perm_debug() {
	ls -lai "$@" 1>&2 2>/dev/null || true
	if which handle &>/dev/null; then
		for i in "$@"; do
			(cd /tmp && handle "$(basename "$i")" -nobanner) 1>&2 || true
		done
	fi
}

function ck_clone() {
	set -x

	local sdir="$1"; shift
	local bdir="$1"; shift
	local odir="$1"; shift
	local cdir="$1"; shift
	local plugin="$1"; shift
	local mode="$1"; shift
	local type="$1"; shift
	local area="$1"; shift
	local area_ck="$1"; shift
	local cur="$1"; shift
	local max="$1"; shift
	local job="$1"; shift
	local manual="$1"; shift
	local ctl_log="$1"; shift

	local plugin_base="${plugin/%.es[pm]}"

	set -e
	set -o pipefail

	ctl_log "$ctl_log" "$job" "$plugin" "$mode" "$type" "$area" "$area_ck" "CLONING"

	# Exclude anything not needed for automated processes like PC/PV generation
	if ((!MANUAL)); then
		EXCLUDE_AUTOMATED_AUX=1
	fi

	# Exclude files precombine generation may be involved with generating
	case "$mode" in
	precombine)
		EXCLUDE_PC_AUX=1
		;;
	esac

	# Hardlink base directory contents to per-build directories
	rsync -aSH \
		--delete \
		--delete-excluded \
		--exclude "${odir}*" \
		--exclude "${bdir}*" \
		--exclude "${cdir}*" \
		--exclude [pP]reCombined* \
		--exclude [vV]is* \
		--exclude [iI]nterface \
		--exclude [sS]trings \
		--exclude [sS]cripts \
		--exclude [tT]extures \
		--exclude [sS]ound \
		--exclude [mM]usic \
		--exclude [vV]ideo \
		--exclude MCM \
		--exclude F4SE \
		--exclude Backup \
		--exclude Edit\ Scripts \
		--exclude CheckinBackup \
		--exclude VersionBackup \
		--exclude log.txt \
		--exclude EditorWarnings.txt \
		--exclude dumpneededfiles.out \
		--exclude output.tome \
		--exclude input.scene \
		--exclude input.scene.json \
		--exclude CombinedObjects.esp \
		--exclude PreVis.esp \
		--exclude 'CreationKit*.ini' \
		--exclude 'enbseries' \
		--exclude 'auto_backup_executable' \
		--exclude 'FO4Edit*' \
		--exclude 'f4se*.dll' \
		--exclude 'x3d*.dll' \
		--exclude 'd3d*.dll' \
		--exclude 'la_d3d*.dll' \
		${EXCLUDE_AUTOMATED_AUX:+--exclude '*Sounds*.ba2'} \
		${EXCLUDE_AUTOMATED_AUX:+--exclude '*Textures*.ba2'} \
		${EXCLUDE_AUTOMATED_AUX:+--exclude '*Voices*.ba2'} \
		${EXCLUDE_PC_AUX:+--exclude '*.cdx'} \
		${EXCLUDE_PC_AUX:+--exclude '*.csg'} \
		${EXCLUDE_PC_AUX:+--exclude '*.psg'} \
		--link-dest="$sdir" "$sdir"/ "$bdir/$job"/
#		--exclude "$SELF*" \
#		--exclude '*.es[pml]' \

	# Move any esms into place as they should be considered the most up to date.
	# Note: CK will stow know VC is enabled due to network shared dirs in the ini files.
	if [[ -d "$bdir/$job/Data/Merging" ]]; then
		find "$bdir/$job/Data/Merging" -maxdepth 1 -type f -name '*.esm' -print0 | xargs -tr0 mv -t "$bdir/$job/Data"
		rm -rf "$bdir/$job/Data/Merging"
	fi

	# Hardcopy CK ini files
	rsync -aS --include 'CreationKit*.ini' --exclude '*' "$sdir"/ "$bdir/$job"/

	# Explicitly remove CK prefs ini so it'll be regenerated from a clean slate to avoid strange behavior.
	rm "$bdir/$job/CreationKitPrefs.ini"
#	cp /dev/null "$bdir/$job/CreationKitPrefs.ini"

	# Alter build-dir versions of CK ini files
	for j in "$bdir/$job/CreationKit.ini" "$bdir/$job/CreationKitPrefs.ini" "$bdir/$job/CreationKitCustom.ini"; do
		[[ -f "$j" ]] && ck_ini_rewrite "$bdir" "$job" < "$j" > "$j.tmp" && mv "$j.tmp" "$j"
	done

	# Hardlink cached archives (if any) into build-dir (this won't affect the original archives)
	if [[ -d "$cdir/Data" ]]; then
		rsync -aSH --link-dest="$sdir/$cdir/Data" "$sdir/$cdir/Data"/ "$bdir/$job/Data"/
	fi

	# Clone plugin specific archive so that later archive rewrites don't run into
	# concurrent access issues (e.g. Permission denied).
	find "$bdir/$job/Data" -maxdepth 1 -mindepth 1 -type f -name "$plugin_base - *.ba2" | while read tmp; do
		while ! cp --remove-destination -fp "$tmp" "$tmp.$$"; do
			perm_debug "$tmp" "$tmp.$$"
			sleep 1
		done
		while ! mv "$tmp.$$" "$tmp"; do
			perm_debug "$tmp" "$tmp.$$"
			sleep 1
		done
	done

	# XXX: Update comment to be master specific.
	# Original plugins, can be useful in cases where masters should be
	# pulled in but not all of their extended masters (i.e. ckgen style).
	# The actual use case is rather specific in where a large amount of
	# masters are involved and handle limits are being hit in CK, which
	# prevents generation of any data.
	if [[ -d "$bdir/$job/Data/ckgen" ]]; then
		# Multiple finds are used to workaround cp complaining about files it just
		# overwrote. rsync is not an option because it sorts the input list.

		# Copy of plugins from Data/ckgen/*
		(find \
			"$bdir/$job/Data/ckgen"{"","/$plugin"}{"","/$type","/$area","/$type/$area","/$area/$type"} \
			-maxdepth 1 -mindepth 1 -type f -printf '%h\n' 2>/dev/null || true) \
			| awk '!seen[$0]++' \
			| while read tmp
		do
			find "$tmp" -maxdepth 1 -mindepth 1 -type f -print0 \
				| xargs -tr0 cp --remove-destination -flpt "$bdir/$job/Data"
		done || return 1

		# Copy of plugins specifically setup as masters from Data/ckgen/master/*
		(find \
			"$bdir/$job/Data/ckgen"{"","/$plugin"}{"","/$type","/$area","/$type/$area","/$area/$type"}/master \
			"$bdir/$job/Data/ckgen/master"{"","/$plugin"}{"","/$type","/$area","/$type/$area","/$area/$type"} \
			-maxdepth 1 -mindepth 1 -type f '!' -name "${plugin/.es[pml]*/.es[pml]}*" -printf '%h\n' 2>/dev/null || true) \
			| awk '!seen[$0]++' \
			| while read tmp
		do
			find "$tmp" -maxdepth 1 -mindepth 1 -type f '!' -name "${plugin/.es[pml]*/.es[pml]}*" -print0 \
				| xargs -tr0 cp --remove-destination -flpt "$bdir/$job/Data"
		done || return 1
	fi

	# Propogate info file with information about cloned environment
	echo -e "$sdir\t$bdir\t$odir\t$cdir\t$plugin\t$mode\t$type\t$area\t$area_ck\t$cur\t$max\t$job\t$manual\t$$" > $bdir/$job/ck_wrap.info

	return 0
}

function ck_archive_wrap_unpack() {
	date 1>&2 || true
	ls -lai "$1" 1>&2 2>/dev/null
	Tools/Archive2/Archive2.exe "$1" -e="$2" -q
	find "$2" -ls 1>&2
	date 1>&2 || true
}

function ck_archive_wrap_pack() {
	# Archive2 refuses to create empty archives
	find "$1" -type f '!' -empty 2>/dev/null | egrep '' &>/dev/null || echo 'empty' > "$1/empty.txt"

	date 1>&2 || true
	ps -efW | egrep Archive2 || true
	ls -lai "$2" 1>&2 2>/dev/null || true
	find "$1" -ls 1>&2
	Tools/Archive2/Archive2.exe "$1" -c="$2.$$" -compression="${3:-Default}" -q
	while ! mv "$2.$$" "$2"; do
		perm_debug "$2.$$" "$2"
		sleep 1
	done
	date 1>&2 || true
}

function ck_archive_rewrite() {
	set -x

	local bdir="$1"; shift
	local job="$1"; shift
	local method="$1"; shift
	local plugin="$1"; shift

	local plugin_base="${plugin/%.es[pml]}"
	local plugin_esm="${plugin/%.esp/.esm}"
	local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	local plugin_ck_base="${plugin_ck/%.es[pml]}"

	local archive_type="Main"
	local archive_main="$bdir/$job/Data/$plugin_base - $archive_type.ba2"
	local archive_main_ck="$bdir/$job/Data/$plugin_ck_base - $archive_type.ba2"

	set -e
	set -o pipefail

	if [[ ! -f "$archive_main" ]]; then
		return 0
	elif [[ "$plugin" == "$plugin_ck" ]]; then
		return 0
	fi

	case "$method" in
	sanitize)
		local archive_data_tmp="$bdir/$job/.archive_tmp/Data"

		if [[ "$archive_main" != "$archive_main_ck" ]]; then
			while ! cp -flp --remove-destination "$archive_main" "$archive_main_ck"; do
				perm_debug "$archive_main" "$archive_main_ck"
				sleep 1
			done
		fi

		OIFS="$IFS";
		IFS="
"
		local -a masters=( $(plugin-master-reloc -qr "$bdir/$job/Data/$plugin" | awk '!seen[$0]++') )
		IFS="$OIFS"

		for __plugin in "$plugin" "${masters[@]}"; do
			local __plugin_base="${__plugin/%.es[pml]}"
			local __plugin_esm="${__plugin/%.esp/.esm}"
			local __plugin_sanitized="${__plugin_esm//[^A-Za-z0-9_.-]/_}"
			local __plugin_ck="${__plugin_sanitized:-${__plugin_esm:-$__plugin}}"
			local __plugin_ck_base="${__plugin_ck/%.es[pml]}"
			local __plugin_sub="$__plugin_esm"
			local __plugin_sub_base="$__plugin_base"

			# If the target is the plugin itself, then the ck-sanitized name
			# should be used - otherwise the esm-extension name should be used
			# as esp masters are simply flipped to esm extensions.
			if [[ "$__plugin" == "$__plugin_ck" ]]; then
				continue
			elif [[ "$__plugin" == "$plugin" ]]; then
				__plugin_sub="$__plugin_ck"
				__plugin_sub_base="$__plugin_ck_base"
			fi

			if [[ ! -d "$archive_data_tmp" ]]; then
				# Speed-hack to avoid archive extraction unless it's absolutely necessary.
				egrep -qi "$__plugin|$__plugin_base.*strings" "$archive_main" || continue

				while ! cp -flp --remove-destination "$archive_main" "$archive_main.save"; do
					perm_debug "$archive_main" "$archive_main.save"
					sleep 1
				done

				mkdir -p "$archive_data_tmp"
				ck_archive_wrap_unpack "$archive_main_ck" "$archive_data_tmp"
			fi

			# Account for plugin-specific dirs
			if [[ "$__plugin" != "$__plugin_sub" ]]; then
				find "$archive_data_tmp" -type d -name "$__plugin" -print0 \
					| xargs -tr0 rename "$__plugin" "$__plugin_sub"
			fi

			# Account for mixed case base string files
			if [[ "$__plugin_base" != "$__plugin_sub_base" ]]; then
				for ___plugin_base in "${__plugin_base}" "${__plugin_base^^}" "${__plugin_base,,}"; do
					find "$archive_data_tmp" -type f -name "${___plugin_base}*" -iname '*strings' -print0 \
						| xargs -tr0 rename "$___plugin_base" "$__plugin_sub_base"
				done
			fi
		done

		if [[ -d "$archive_data_tmp" ]]; then
			ck_archive_wrap_pack "$archive_data_tmp" "$archive_main_ck" 'Default'
			rm -rf "$archive_data_tmp"
		fi

		;;
	restore)
		ls -lai "$archive_main.save" "$archive_main" "$archive_main_ck" 1>&2 2>/dev/null || true
		if [[ "$archive_main" != "$archive_main_ck" ]]; then
			rm -f "$archive_main_ck"
		fi
		if [[ -f "$archive_main.save" ]]; then
			while ! rm -f "$archive_main"; do
				perm_debug "$archive_main"
				sleep 1
			done
			while ! mv "$archive_main.save" "$archive_main"; do
				perm_debug "$archive_main.save" "$archive_main"
				sleep 1
			done
		fi
		;;
	esac

	return 0
}

function ck_archive_wrap() {
	set -x

	local bdir="$1"; shift
	local cdir="$1"; shift
	local ctl_log="$1"; shift
	local plugin="$1"; shift
	local mode="$1"; shift
	local type="$1"; shift
	local area="$1"; shift
	local area_ck="$1"; shift
	local job="$1"; shift

	set -e
	set -o pipefail

	local plugin_base="${plugin/%.es[pml]}"
	local plugin_esm="${plugin/%.esp/.esm}"
	local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	local plugin_ck_base="${plugin_ck/%.es[pml]}"
	local archive_type="Main"

	case "$mode" in
	scol)
		if [[ -f "$bdir/$job/Data/$plugin_base - Meshes.ba2" ]]; then
			archive_type="Meshes"
		fi
		;;
	precombine|previs)
		if [[ -f "$bdir/$job/Data/$plugin_base - MeshesExtra.ba2" ]]; then
			archive_type="MeshesExtra"
		fi
		;;
	esac

	local archive_main="$bdir/$job/Data/$plugin_base - $archive_type.ba2"
	local archive_main_cached="$cdir/Data/$plugin_base - $archive_type.ba2"
	local cleaned_marker="$cdir/tmp/$plugin.$mode.cleaned"
	local cache_lock="$cdir/tmp/$plugin.lock"
	local modified=0

	# Multiple jobs may be generating data which is stored in the
	# same backing archive. As such, it should be lock-controlled
	# to prevent race conditions on update.
	if ! lockfile -l 3600 -r 3600 -1 "$cache_lock"; then
		echo "Failed to acquire lock: $cache_lock ..." 1>&2
		return 1
	fi

	# Note: There are limitations in CK around the maximum number
	# of cached file handles involved with loose files. Since
	# Data/Meshes/PreCombined usually contains over 100k files
	# for a full generation an archive needs to be used for any
	# further generation depending on those files (e.g. previs).

	case "$mode" in
	scol)		local ddir="Meshes/SCOL" ;;
	precombine)	local ddir="Meshes/PreCombined" ;;
	previs)		local ddir="Vis" ;;
	*)		return 1 ;;
	esac

	# Bail if the directory to archive doesn't exist.
	[[ -d "$bdir/$job/Data/$ddir" ]] || return 0

	ctl_log "$ctl_log" "$job" "$plugin" "$mode" "$type" "$area" "$area_ck" "ARCHIVING"

	local archive_data_tmp="$bdir/$job/.archive_tmp/Data"
	if [[ -d "$archive_data_tmp" ]]; then
		echo "Assertion failure: $archive_data_tmp exists" 1>&2
		find "$archive_data_tmp" -ls 1>&2
		return 1
	fi
	mkdir -p "$archive_data_tmp"

	local archive_src
	if [[ -f "$archive_main_cached" ]]; then
		archive_src="$archive_main_cached"
	elif [[ -f "$archive_main" ]]; then
		archive_src="$archive_main"
	fi

	# It's entirely commonly that an archive being updated
	# *may* not actually exist yet.
	[[ -f "$archive_src" ]] && ck_archive_wrap_unpack "$archive_src" "$archive_data_tmp"

	# Remove archived data for the same type being updated
	# to prevent cruft - but only do it once in case of
	# concurrent runs (shards, etc).
	if [[ ! -f "$cleaned_marker" ]]; then
		rm -rf "$archive_data_tmp/$ddir"
		touch "$cleaned_marker"
	fi

	mkdir -p "$archive_data_tmp/$ddir"
	rsync -aSH \
		--link-dest="$PWD/$bdir/$job/Data/$ddir" \
		"$bdir/$job/Data/$ddir"/ "$archive_data_tmp/$ddir"/

	ck_archive_wrap_pack "$archive_data_tmp" "$archive_main"
	while ! cp --remove-destination -flp "$archive_main" "$archive_main_cached"; do
		perm_debug "$archive_main" "$archive_main_cached"
		sleep 1
	done

	rm -rf "$archive_data_tmp"
	rm -f "$cache_lock"

	ls -lai "$archive_main" "$archive_main_cached" 1>&2 2>/dev/null || true

	return 0
}

function ck_needed_filter() {
	local from="$1"; shift
	local to="$1"; shift

	sed -e "s#${from}#${to}#g" | tr -d '[\r\0\031]' | tr '\\' '/'
}

function ck_geom_wrap() {
	set -x

	local bdir="$1"; shift
	local job="$1"; shift
	local plugin="$1"; shift

	local plugin_base="${plugin/%.es[pml]}"
	local plugin_esm="${plugin/%.esp/.esm}"
	local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	local plugin_ck_base="${plugin_ck/%.es[pml]}"

	set -e
	set -o pipefail

	if [[ "$plugin" == "$plugin_ck" ]]; then
		return
	fi

	if [[ -f "$plugin_base - Geometry.psg" ]]; then
		cp --remove-destination -flp "$plugin_base - Geometry.psg" "$plugin_ck_base - Geometry.psg"
	fi

	if [[ -f "$plugin_base - Geometry.csg" ]]; then
		cp --remove-destination -flp "$plugin_base - Geometry.csg" "$plugin_ck_base - Geometry.csg"
	fi

	return 0
}

function ck_plugin_master_wrap() {
	set -x

	local bdir="$1"; shift
	local job="$1"; shift
	local method="$1"; shift
	local plugin="$1"; shift
	local plugin_src="${1:-$plugin}"; shift || true

	local plugin_base="${plugin/%.es[pml]}"
	local plugin_esm="${plugin/%.esp/.esm}"
	local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	local plugin_ck_base="${plugin_ck/%.es[pml]}"

	set -e
	set -o pipefail

	case "$method" in
	esp-to-esm)
		plugin-master-reloc -vfr --copy-plugin-to-esm --esp-to-esm --sub "$plugin_base:$plugin_ck_base" "$bdir/$job/Data/$plugin_src"
#		plugin-master-reloc -vr "$bdir/$job/Data/$plugin_ck"

		;;
	esm-to-esp)
		plugin-master-reloc -vfr --esm-to-esp --sub "$plugin_ck_base:$plugin_base" "$bdir/$job/Data/$plugin_src"
#		plugin-master-reloc -vr "$bdir/$job/Data/$plugin"

		;;
	esac

	return 0
}

function ck_output_dir_rename() {
	set -x

	local bdir="$1"; shift
	local job="$1"; shift
	local dir="$1"; shift
	local plugin="$1"; shift

	local plugin_base="${plugin/%.es[pml]}"
	local plugin_esm="${plugin/%.esp/.esm}"
	local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	local plugin_ck_base="${plugin_ck/%.es[pml]}"

	set -e
	set -o pipefail

	# Ensure all plugins using esp masters (including their masters) are temporarily
	# altered to use esm masters instead.
	OIFS="$IFS"
	IFS="
"
	local -a masters=( $(plugin-master-reloc -qr "$bdir/$job/Data/$plugin" | awk '!seen[$0]++') )
	IFS="$OIFS"

	for __plugin in "$plugin" "${masters[@]}"; do
		local __plugin_base="${__plugin/%.es[pml]}"
		local __plugin_esm="${__plugin/%.esp/.esm}"
		local __plugin_sanitized="${__plugin_esm//[^A-Za-z0-9_.-]/_}"
		local __plugin_ck="${__plugin_sanitized:-${__plugin_esm:-$__plugin}}"
		local __plugin_ck_base="${__plugin_ck/%.es[pml]}"
		local __plugin_sub="$__plugin_esm"

		# If plugin name or masters have been sanitized or flipped to an esm,
		# change any directory references back to the original plugin name.
		if [[ "$__plugin" == "$__plugin_ck" ]]; then
			continue
		elif [[ "$__plugin" == "$plugin" ]]; then
			__plugin_sub="$__plugin_ck"
		fi

		find "$bdir/$job/$dir" -type d -name "$__plugin_sub" -print0 \
			| xargs -tr0 rename "$__plugin_sub" "$__plugin"
	done

	return 0
}

function ck_exec_wrap() {
	set -x

	local bdir="$1"; shift
	local cdir="$1"; shift
	local plugin="$1"; shift
	local mode="$1"; shift
	local type="$1"; shift
	local area="$1"; shift
	local area_ck="$1"; shift
	local cur="$1"; shift
	local max="$1"; shift
	local job="$1"; shift
	local manual=$1; shift;
	local target
	local -a args

	# Equalized width of $cur
	local wcur=$(printf "%02d" $cur)

	local plugin_base="${plugin/%.es[pml]}"
	local plugin_esm="${plugin/%.esp/.esm}"
	local plugin_sanitized="${plugin_esm//[^A-Za-z0-9_.-]/_}"
	local plugin_ck="${plugin_sanitized:-${plugin_esm:-$plugin}}"
	local plugin_ck_base="${plugin_ck/%.es[pml]}"

	set -e
	set -o pipefail

	# Sanitize any shared geometry files
	ck_geom_wrap "$bdir" "$job" "$plugin"

	# Sanitize archive filename and embedded filenames within archive
	ck_archive_rewrite "$bdir" "$job" "sanitize" "$plugin"

	# Sanitize masters to be compatible with ck args (no spaces) and archives
	ck_plugin_master_wrap "$bdir" "$job" "esp-to-esm" "$plugin"

	case "$mode" in
	scol)
		target='generatestaticcollections'
		args=( -$target:"$plugin_ck" x64 )

		rm -rf "$bdir/$job/Data/Meshes/SCOL"

		;;
	precombine)
		target='generateprecombined'
		args=( -$target:"$plugin_ck" $type $area_ck $cur $max )

		rm -rf "$bdir/$job/Data/Meshes/PreCombined" "$bdir/$job/Data/$plugin_ck_base - Geometry".{csg,psg}

		;;
	previs)
		target='generateprevisdata'
		args=( -$target:"$plugin_ck" $type $area_ck $cur $max )

		rm -rf "$bdir/$job/Data/Vis"

		;;
	csg)
		target='compresspsg'
		args=( -$target:"$plugin_ck" )

		rm -rf "$bdir/$job/Data/$plugin_ck_base - Geometry.csg"

		;;
	cdx)
		target='buildcdx'
		args=( -$target:"$plugin_ck" )

		rm -rf "$bdir/$job/Data/$plugin_ck_base.cdx"

		;;
	needed)
		target='dumpneededfiles'
		args=( -$target:"$plugin_ck" "dumpneededfiles.out" )

		rm -rf "$bdir/$job/Data/dumpneededfiles.out"

		;;
	esac

	# If in manual mode, respect the $mode functionality, but start CK interactively.
	((manual)) && args=()

	if ( \
		cd "$bdir/$job" \
			&& eval "$CKEXEC ${args[*]} &>$CKEXEC_OUT" \
			&& ! egrep -q 'OUT OF HANDLE|Could not get file pointer' "EditorWarnings.txt" \
	);
	then
		cat "$bdir/$job/DataFiles.txt" 1>&2 2>/dev/null || true

		echo "SUCCESS ($target)" >> "$bdir/$job/EditorWarnings.txt"
		mkdir -p "$bdir/$plugin"
		cp --remove-destination -fp "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin/EditorWarnings.$mode.$type.$area.$wcur.$target.txt"
	else
		if fgrep -q 'OUT OF HANDLE' "$bdir/$job/EditorWarnings.txt"; then
			echo "FAILURE ($target handles)" >> "$bdir/$job/EditorWarnings.txt"
		elif fgrep -q 'Could not get file pointer' "$bdir/$job/EditorWarnings.txt"; then
			echo "FAILURE ($target file)" >> "$bdir/$job/EditorWarnings.txt"
		else
			echo "FAILURE ($target)" >> "$bdir/$job/EditorWarnings.txt"
		fi

		cp --remove-destination -fp "$bdir/$job/EditorWarnings.txt" "$bdir/$plugin.$mode.$type.$area.$wcur.$target.error"
		return 1
	fi

	# Restore original archive and remove temporaries
	ck_archive_rewrite "$bdir" "$job" "restore" "$plugin"

	case "$mode" in
	scol)
		if [[ -d "$bdir/$job/Data/Meshes/SCOL" ]]; then
			ck_output_dir_rename "$bdir" "$job" "Data/Meshes/SCOL" "$plugin"
		fi

		;;

	precombine)
		# XXX: Look for any newly added or modified files instead of CombinedObjects.esp specifically?
		# XXX: Might be useful for cases where manual mode is used and a different plugin is saved.
		if [[ -f "$bdir/$job/Data/CombinedObjects.esp" ]]; then
			# If the plugin was copied to an esm, switch esm masters back to esp masters
			ck_plugin_master_wrap "$bdir" "$job" "esm-to-esp" "$plugin" "CombinedObjects.esp"

			# If run in clean mode a shared geometry psg file will be produced that
			# should be compressed with CreationKit.exe -CompressPSG:<plugin_base>.
			# A CDX file should also be produced with -BuildCDX although it's not
			# strictly necessary that the PSG file be compressed first.
			if [[ -f "$bdir/$job/Data/$plugin_ck_base - Geometry.psg" ]]; then
				rename "$plugin_ck_base" "$plugin_base" "$bdir/$job/Data/$plugin_ck_base - Geometry.psg"
			fi
		fi

		if [[ -d "$bdir/$job/Data/Meshes/PreCombined" ]]; then
			ck_output_dir_rename "$bdir" "$job" "Data/Meshes/PreCombined" "$plugin"
		fi

		;;

	previs)
		# XXX: Look for any newly added or modified files instead of CombinedObjects.esp specifically?
		# XXX: Might be useful for cases where manual mode is used and a different plugin is saved.
		if [[ -f "$bdir/$job/Data/PreVis.esp" ]]; then
			ck_plugin_master_wrap "$bdir" "$job" "esm-to-esp" "$plugin" "PreVis.esp"
		fi

		if [[ -d "$bdir/$job/Data/Vis" ]]; then
			ck_output_dir_rename "$bdir" "$job" "Data/Vis" "$plugin"
		fi

		;;

	csg)
		if [[ -f "$bdir/$job/Data/$plugin_ck_base - Geometry.csg" ]]; then
			rename "$plugin_ck_base" "$plugin_base" "$bdir/$job/Data/$plugin_ck_base - Geometry.csg"
		fi

		;;

	cdx)
		if [[ -f "$bdir/$job/Data/$plugin_ck_base.cdx" ]]; then
			rename "$plugin_ck_base" "$plugin_base" "$bdir/$job/Data/$plugin_ck_base.cdx"
		fi

		;;

	needed)
		if [[ -f "$bdir/$job/Data/dumpneededfiles.out" ]]; then
			ck_needed_filter "$plugin_ck" "$plugin" \
				< "$bdir/$job/dumpneededfiles.out" \
				> "$bdir/$job/dumpneededfiles.out.tmp" \
				&& mv "$bdir/$job/dumpneededfiles.out.tmp" "$bdir/$job/dumpneededfiles.out"

			# If the plugin was copied to an esm or sanitized, change any references in dumpneededfiles.out
			# XXX: Masters?
			if [[ "$plugin_ck" != "$plugin" ]]; then
				sed -i -e "s#$plugin_ck#$plugin#g" "$bdir/$job/dumpneededfiles.out"
			fi
		fi

		;;
	esac

	return 0
}

function ck_wrap() {
	set -x

	local sdir="$1"; shift
	local bdir="$1"; shift
	local odir="$1"; shift
	local cdir="$1"; shift
	local plugin="$1"; shift
	local mode="$1"; shift
	local type="$1"; shift
	local area="$1"; shift
	local area_ck="$1"; shift
	local cur="$1"; shift
	local max="$1"; shift
	local job="$1"; shift
	local manual="$1"; shift
	local ctl_log="$1"; shift

	# Equalized width of $cur
	local wcur=$(printf "%02d" $cur)
	local plugin_base="${plugin/%.es[pml]}"

	set -e
	set -o pipefail
	set -o errtrace

	rm -f "$bdir/$job/EditorWarnings.txt"
	trap "echo 'FAILURE' >> '$bdir/$job/EditorWarnings.txt'; ls -d '$bdir/$plugin.$mode.$type.$area.$wcur'.*.error &>/dev/null || cp --remove-destination -fp '$bdir/$job/EditorWarnings.txt' '$bdir/$plugin.$mode.$type.$area.$wcur.ck_wrap.error'" ERR

	ck_clone "$sdir" "$bdir" "$odir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual" "$ctl_log"

	# For each given mode, nuke any old data left in per-job build
	# directory, regenerate it with CK, and then move the results
	# to the output directory.
	case "$mode" in
	scol)
		ck_exec_wrap "$bdir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual"

		if [[ -d "$bdir/$job/Data/Meshes/SCOL" ]]; then
			ck_archive_wrap "$bdir" "$cdir" "$ctl_log" "$plugin" "$mode" "$type" "$area" "$area_ck" "$job"

			mkdir -p "$bdir/$plugin/Data/Meshes"
			mv "$bdir/$job/Data/Meshes/SCOL" "$bdir/$plugin/Data/Meshes/SCOL"
		fi

		;;

	precombine)
		ck_exec_wrap "$bdir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual"

		# XXX: Look for any newly added or modified files instead of CombinedObjects.esp specifically?
		# XXX: Might be useful for cases where manual mode is used and a different plugin is saved.
		if [[ -f "$bdir/$job/Data/CombinedObjects.esp" ]]; then
			# If run in clean mode a shared geometry psg file will be produced that
			# should be compressed with CreationKit.exe -CompressPSG:<plugin_base>.
			# A CDX file should also be produced with -BuildCDX although it's not
			# strictly necessary that the PSG file be compressed first.
			if [[ -f "$bdir/$job/Data/$plugin_base - Geometry.psg" ]]; then
				# Copy into cached data so subsequent runs will have access to shared geometry (e.g. previs)
				cp --remove-destination -flp "$bdir/$job/Data/$plugin_base - Geometry.psg" "$cdir/Data/$plugin_base - Geometry.psg"

				mkdir -p "$bdir/$plugin/Data"
				mv "$bdir/$job/Data/$plugin_base - Geometry.psg" "$bdir/$plugin/Data/$plugin_base - Geometry.psg"
			fi

			mkdir -p "$bdir/$plugin/Data"
			mv "$bdir/$job/Data/CombinedObjects.esp" "$bdir/$plugin/Data/$plugin.$mode.$type.$area.$wcur.esp"
		fi

		if [[ -d "$bdir/$job/Data/Meshes/PreCombined" ]]; then
			ck_archive_wrap "$bdir" "$cdir" "$ctl_log" "$plugin" "$mode" "$type" "$area" "$area_ck" "$job"

			mkdir -p "$bdir/$plugin/Data/Meshes"
			mv "$bdir/$job/Data/Meshes/PreCombined" "$bdir/$plugin/Data/Meshes/PreCombined.$area.$wcur"
		fi

		;;

	previs)
		ck_exec_wrap "$bdir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual"

		# XXX: Look for any newly added or modified files instead of PreVis.esp specifically?
		# XXX: Might be useful for cases where manual mode is used and a different plugin is saved.
		if [[ -f "$bdir/$job/Data/PreVis.esp" ]]; then
			mkdir -p "$bdir/$plugin/Data"
			mv "$bdir/$job/Data/PreVis.esp" "$bdir/$plugin/Data/$plugin.$mode.$type.$area.$wcur.esp"
		fi

		if [[ -d "$bdir/$job/Data/Vis" ]]; then
			ck_archive_wrap "$bdir" "$cdir" "$ctl_log" "$plugin" "$mode" "$type" "$area" "$area_ck" "$job"

			mkdir -p "$bdir/$plugin/Data"
			mv "$bdir/$job/Data/Vis" "$bdir/$plugin/Data/Vis.$area.$wcur"
		fi

		;;

	csg)
		# Using CombinedObjects.esp is perfectly fine as long as the requisite
		# XCRI data (which it contains), PSG or CSG file, and precombined NIFs
		# are accessible to the -BuildCDX codepath. The PSG data will be loaded
		# by one of the masters of CombinedObjects.esp and that's all the engine
		# needs (it doesn't need to explicitly match the file base). This ability
		# is highly convenient as it avoids having to copy CombinedObjects.esp to
		# a temporary file with the same file base.

		ck_exec_wrap "$bdir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual"

		# Copy into cached data so subsequent runs will have access to shared geometry (e.g. previs)
		cp --remove-destination -flp "$bdir/$job/Data/$plugin_base - Geometry.csg" "$cdir/Data/$plugin_base - Geometry.csg"

		# -BuildCDX depends on these files and the emitted plugin to generate accurate data. As such
		# they should be moved after both -CompressPSG and -BuildCDX are finished.
		mkdir -p "$bdir/$plugin/Data"
		mv -t "$bdir/$plugin/Data" "$bdir/$job/Data/$plugin_base - Geometry.csg"

		;;

	cdx)
		# Generate "cell resource index" (SCellResourceIndexFileList) for a given
		# plugin which is known to use shared precombine data combined with XCRI
		# and XPRI records to generate an index database used by the game itself.
		# Additionally, if a plugin makes use of both shared-geom and non-shared
		# geom precombines the cdx file must be updated to reflect that.

		ck_exec_wrap "$bdir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual"

		mkdir -p "$bdir/$plugin/Data"
		mv -t "$bdir/$plugin/Data" "$bdir/$job/Data/$plugin_base.cdx"

		;;

	needed)
		ck_exec_wrap "$bdir" "$cdir" "$plugin" "$mode" "$type" "$area" "$area_ck" "$cur" "$max" "$job" "$manual"

		mkdir -p "$bdir/$plugin"
		mv "$bdir/$job/dumpneededfiles.out" "$bdir/$plugin/$plugin.$mode.$type.$area.$wcur.dumpneededfiles.out"

		;;
	esac

	# Copy plugin used for generation for reference purposes
	if [[ -n "$plugin" && -f "$bdir/$job/Data/$plugin" ]]; then
		mkdir -p "$bdir/$plugin"
		cp --remove-destination -flp "$bdir/$job/Data/$plugin" "$bdir/$plugin/$plugin.$mode.$type.$area"
	fi

	echo "SUCCESS" >> "$bdir/$job/EditorWarnings.txt"

	return 0
}

function ck_wrap_proc() {
	set -x

	local bdir="$1"; shift
	local odir="$1"; shift
	local plugin="$1"; shift

	set -e
	set -o pipefail

	if [[ -d "$bdir/$plugin" ]]; then
		if ls -d "$bdir/$plugin/Data/Meshes/SCOL" 2>/dev/null; then
			echo "$plugin: Moving static collections..." 1>&2
		fi

		if ls -d "$bdir/$plugin/Data/Meshes/PreCombined".* 2>/dev/null; then
			echo "$plugin: Moving precombined..." 1>&2
		fi

		if ls -d "$bdir/$plugin/Data/Vis".* 2>/dev/null; then
			echo "$plugin: Moving previs..." 1>&2
		fi

		if ls -d "$bdir/$plugin/Data"/*.[pc]sg 2>/dev/null; then
			echo "$plugin: Moving shared geometry..." 1>&2
		fi

		if ls -d "$bdir/$plugin/Data"/*.cdx 2>/dev/null; then
			echo "$plugin: Moving cell resource index..." 1>&2
		fi

		if ls -d "$bdir/$plugin/Data"/*.esp 2>/dev/null; then
			echo "$plugin: Moving generated plugins..." 1>&2
		fi

		if (ls -d "$bdir/$plugin/$plugin".*.{all,main,ints,other} 2>/dev/null || true) | grep ''; then
			echo "$plugin: Moving reference plugins..." 1>&2
		fi

		if ls -d "$bdir/$plugin"/*.dumpneededfiles*out 2>/dev/null; then
			echo "$plugin: Moving needed files output..." 1>&2
		fi

		if ls -d "$bdir/$plugin"/EditorWarnings*.txt 2>/dev/null; then
			echo "$plugin: Moving editor warnings output..." 1>&2
		fi

		if ls -d "$bdir/$plugin/jobs" 2>/dev/null; then
			echo "$plugin: Moving job output..." 1>&2
		fi
	fi | sed -e "s#$bdir/$plugin#$plugin#g" \
		| rsync --protect-args -aS -r --relative --files-from=- --link-dest="$PWD/$bdir" "$bdir" "$odir"

	if ls -d "$bdir/$plugin".*.error &>/dev/null; then
		echo "$plugin: Moving error output..." 1>&2

		mkdir -p "$odir"
		mv -t "$odir" "$bdir/$plugin".*.error || true
	fi

	# XXX: hardlink plugins into Data?
	if false && ((MERGE)); then
		echo "$plugin: Merging plugins..." 1>&2

		# XXX: Plugins might have to be in Data first
		# Could not parse command line properly.  Should be -CheckInPlugin:<PluginFilename> <ESMFilename>
		find "$odir/$plugin" -type f -name '*.esp' -print0 \
			| xargs -I{} -tr0 -n1 ./CreationKit.exe -checkinplugin:{} $plugin
	fi
}

function ck_log_wrap() {
	local build="$1"; shift
	local wrap_mode="$1"; shift
	local jobs="$1"; shift

	set -e
	set -o pipefail

	# Precompute filenames rather than rely on shell globbing as they're usually
	# non-existent when tail starts (and tail -F handles that issue on it's own).
	local -a logs=( \
		"$build/tmp/ctl.log" \
		$(printf "$build/%s/EditorWarnings.txt " $(seq -s ' ' 1 $jobs)) \
		$(printf "$build/%s/$CKEXEC_OUT " $(seq -s ' ' 1 $jobs)) \
	)

	echo $$ > "$build/tmp/ck_log_wrap.$wrap_mode.pid"

	touch "$build/tmp/cell".{main,other,ints}.log

	tail -vn0 -s 0.1 -F "${logs[@]}" 2>/dev/null \
		| LC_ALL=C awk \
			-v wrap_mode="$wrap_mode" \
			-v build_dir="$build" \
			-v ctl_log="$build/tmp/ctl.log" \
			-v main_log="$build/tmp/cell.main.log" \
			-v other_log="$build/tmp/cell.other.log" \
			-v ints_log="$build/tmp/cell.ints.log" \
			-v info_file="ck_wrap.info" '
	BEGIN{
		IGNORECASE=1
	}
	{
		if (!length) {
			next;
		} else if ($0 ~ /^==> /) {
			if (match($0, "^==> .+/([0-9]+)/.+ <==$", a)) {
				id_cur=a[1];
				f = sprintf("%s/%d/%s", build_dir, id_cur, info_file);
				while (getline < f > 0) {
					split($0, info, "\t");
				}
				close(f);
				plugin=info[5];
				mode=info[6];
				type=info[7];
				area=info[8];
				area_ck=info[9];
				ctl=0
			} else if ($0 ~ ctl_log) {
				ctl=1
			}
			next;
		} else if (wrap_mode == "cell") {
			if (ctl) {
				split($0, info, "\t");
				id_cur=info[1];
				plugin=info[2];
				mode=info[3];
				type=info[4];
				area=info[5];
				area_ck=info[6];
				$0=info[7];
				usepcnt=0;
			} else {
				if ($0 !~ /generat.*for.*cell|Number of registered paths|^(SUCCESS|FAILURE)/)
					next;
#				if ($0 ~ /^SUCCESS \(.+\)/)
#					next;
				if ($0 ~ /ROOTCELL/)
					next;
				if ($0 ~ /^(SUCCESS|FAILURE)/)
					usepcnt=0;
				else
					usepcnt=1;

				if ($0 ~ /Generating.* for.*cell/) {
					if ($0 ~ / interior cell /) {
						print > ints_log;
						fflush(ints_log);
					} else if ($0 ~ / Commonwealth /) {
						print > main_log;
						fflush(main_log);
					} else {
						print > other_log;
						fflush(other_log);
					}
				}
			}
		} else if (wrap_mode == "all") {
			if (ctl)
				next;
			if ($0 ~ /gen.*for.*cell/ && $0 !~ /ROOTCELL/)
				next;
			if ($0 ~ /(Warnings|Errors) were encountered|See warnings file/)
				next;
			if ($0 ~ /D3D error|Reference .* attached to wrong cell for its location: Persistent cell|Unable to find reference group/)
				next;
			usepcnt=1;
		} else {
			next;
		}

		if (usepcnt)
			printf("%8d %32.32s %12s %8s %8s [%02d] %8d %s\n", ++cnt, plugin, mode, type, area, id_cur, ++cnttab[plugin], $0);
		else
			printf("%8d %32.32s %12s %8s %8s [%02d] %8s %s\n", ++cnt, plugin, mode, type, area, id_cur, "", $0);
	}'

	return 0
}

function ck_status() {
	set -e

	local build_dir="$1"; shift
	local -a status=( $(awk -v jobs_in="$build_dir/tmp/jobs.in" -v jobs_log="$build_dir/tmp/jobs.log" -v meminfo=/proc/meminfo '
BEGIN{
	total=0
	success=0
	fail=0
	while (getline < jobs_in > 0) {
		total++
	}
	while (getline < jobs_log > 0) {
		if ($1 == "Seq") continue
		else if ($7) fail++
		else success++
	}
	while (getline < meminfo > 0) {
		if ($1 == "MemTotal:") memtotal=$2
		else if ($1 == "MemFree:") memfree=$2
		else if ($1 == "SwapTotal:") swaptotal=$2
		else if ($1 == "SwapFree:") swapfree=$2
	}
}END{
	print total,success,fail,memtotal,memfree,swaptotal,swapfree
}
' "$build_dir/tmp/jobs.log") )
	local -a cell=( "$(wc -l < "$build_dir/tmp/cell.main.log")" "$(wc -l < "$build_dir/tmp/cell.other.log")" "$(wc -l < "$build_dir/tmp/cell.ints.log")" )
	local -a disk=( $(df --output=used,avail "$build_dir") )
	local load=$(uptime)

	printf 'total/success/fail: %s/%s/%s (%d%%) | main/other/ints: %d/%d/%d (%d) | load average: %s | mem free: %d/%d GB (%s%%) | disk free: %d/%d GB (%s%%)\n' \
		"${status[0]}" "${status[1]}" "${status[2]}" $(((status[1]+status[2])*100/status[0])) \
		"${cell[0]}" "${cell[1]}" "${cell[2]}" $((cell[0]+cell[1]+cell[2])) \
		"${load/*load average: }" \
		$((( (status[3]+status[5])-(status[4]+status[6]) )/1024**2)) $(((status[3]+status[5])/1024**2)) $(((status[4]+status[6])*100/(status[3]+status[5]))) \
		$((disk[2]/1024**2)) $(((disk[2]+disk[3])/1024**2)) $((disk[3]*100/(disk[2]+disk[3])))

	return 0
}

TMUX=1
SHARDS=1
SHARDS_START=1
CORES=$(cpu_core_cnt)
THREADS=$(cpu_thread_cnt)
JOBS=$THREADS
SELF=$(basename $0)
CACHE=$SELF.cache
BUILD=$SELF.build
OUT=$SELF.out
TYPE="filtered"
AREA="all"
PRESERVE_CACHE=1
PRESERVE_BUILD=0
PRESERVE_OUT=0
MANUAL=0
DEBUG=0
CKEXEC_OUT="ckexec.out"

if ((DEBUG)); then
	CKEXEC="'/c/Program Files (x86)/Windows Kits/10/Debuggers/x64/windbg.exe' -o -pb -pr ./CreationKit.exe"
else
	CKEXEC="./CreationKit.exe"
fi

if [[ "$1" == "--wrap" ]]; then
	shift; ck_wrap "$@"; ((!$?)) || exit -1
	exit $?
elif [[ "$1" == "--log-wrap" ]]; then
	shift; ck_log_wrap "$@"; ((!$?)) || exit -1
	exit $?
elif [[ "$1" == "--status" ]]; then
	shift; ck_status "$@"; ((!$?)) || exit -1
	exit $?
fi

# XXX: Use -c for cache option?
while getopts "j:s:S:t:PpmMg" opt; do
        case $opt in
	j) JOBS="$OPTARG" ;;
	s) SHARDS="$OPTARG" ;;
	S) SHARDS_START="$OPTARG" ;;
	t) TMUX="$OPTARG" ;;
	p) PRESERVE_OUT=1 ;;
	P) PRESERVE_OUT=1; PRESERVE_BUILD=1 ;;
	m) MERGE=1 ;;
	M) MANUAL=1 ;;
	g) DEBUG=1 ;;
	?) exit -1 ;;
        esac
done; shift $((OPTIND - 1))

PROFILE="$1"; shift
if [[ -z "$PROFILE" ]]; then
	echo "No profile specified" 1>&2
	exit -1
elif [[ ! -d "$PROGDIR/Fallout 4.$PROFILE" ]]; then
	echo "$PROGDIR/Fallout 4.$PROFILE does not exist" 1>&2
	exit -1
fi

SRC="$PROGDIR/Fallout 4.$PROFILE"
cd "$SRC"

if ((!PRESERVE_CACHE)) || [[ ! -d "$CACHE" ]]; then
	echo "Removing cache..." 1>&2
	rm -rf "$CACHE" && mkdir -p "$CACHE" "$CACHE/Data" "$CACHE/tmp" || exit -1
fi

if ((!PRESERVE_BUILD)) || [[ ! -d "$BUILD" ]]; then
	echo "Removing previous build data..." 1>&2
	find "$BUILD" -mindepth 1 -maxdepth 1 \! -regex '.*/[0-9]+$' -print0 \
		| xargs -tr0 rm -rf \
		&& mkdir -p "$BUILD" || exit -1
	# Cleanup any temporary files from prior runs
	rm -rf "$BUILD/tmp" && mkdir -p "$BUILD/tmp"
fi

if ((!PRESERVE_OUT)) || [[ ! -d "$OUT" ]]; then
	echo "Removing previous output data..." 1>&2
	rm -rf "$OUT" && mkdir -p "$OUT" || exit -1
fi

# XXX: checkinplugin?
# Could not parse command line properly.  Should be -GeneratePreCombined:<ESMFilename> [clean,filtered] [all,main,ints,other] [currentset(1-totalsetcount)] [totalsetcount]
# Could not parse command line properly.  Should be -GeneratePreVisData:<ESMFilename> [clean,filtered] [all,main,ints,other] [currentset(1-totalsetcount)] [totalsetcount]
MODE="$1"; shift
case "$MODE" in
needed|scol|cdx)
	SHARDS=1
	SHARDS_FORCE=1
	;;
precombine|previs)
	if ((!MANUAL)); then
		TYPE="$1"; shift
		AREA="$1"; shift
	elif [[ "$1" == "clean" || "$1" == "filtered" ]]; then
		case "$2" in
		ALL*|all*|main*|other*|ints*) shift; shift ;;
		esac
	fi

	if [[ "$TYPE" != "clean" && "$TYPE" != "filtered" ]]; then
		echo "Invalid type: $TYPE" 1>&2
		exit -1
	fi

	AREA=( ${AREA//,/ } )
	for area in ${AREA[*]}; do
		case "$area" in
		ALL) AREA=( main ints other ) ;;
		ALL@*) AREA=( main@${area/*@} ints@${area/*@} other@${area/*@} ) ;;
		all|all@*|main|main@*|ints|ints@*|other|other@*) ;;
		*)
			echo "Invalid area: $area" 1>&2
			exit -1
			;;
		esac
	done
	;;
*)
	echo "Invalid mode: $MODE" 1>&2
	exit -1
	;;
esac

if false; then

# Generate output file of jobs to be run by parallel
for plugin in "$@"; do
	if [[ -d "$plugin" ]]; then
		find "$plugin" -type f -name '*.es[pml]'
	else
		echo "$plugin"
	fi
done | while read plugin; do
	plugin_parse "$plugin" plugin t a s

	# Allow additional type/area keywords to override global value past the point of it's parse.
	case "$plugin" in
	filtered|clean) TYPE="$plugin"; continue ;;
	ALL|ALL,*|ALL@*|all|all,*|all@*|ints|ints,*|ints@*|main|main,*|main@*|other|other,*|other@*) AREA=( "${plugin//,/ }" ); continue ;;
	*)
		if [[ ! "$plugin" =~ \.es[mpl]$ ]]; then
			echo "Invalid plugin: $plugin" 1>&2
			exit -1
		fi
		;;
	esac

	[[ -n $a ]] && atmp=( ${a//,/ } ) || atmp=( ${AREA[*]} )
	[[ -n $t ]] || t=$TYPE
	[[ -n $s ]] && s=$((SHARDS_FORCE ? SHARDS : s)) || s=$SHARDS

	for area in ${atmp[*]}; do
		area_ck="${area/*@}"; area="${area/@*}";
#		if [[ "$area" != "all" && "$MODE" == "precombine" && "$t" == "clean" ]] || [[ "$t" == "clean" && $s -ne 1 ]]; then
		if [[ "$MODE" == "precombine" && "$t" == "clean" && $s -ne 1 ]]; then
			echo "$plugin: Error: generating precombines of type 'clean' cannot be run in parallel or in sub-areas due to inability to merge shared geometry data (PSG/CSG)" 1>&2
			exit -1
#			elif [[ "$area" != "main" && "$area" != "ints" && $s -ne 1 ]]; then
#				echo "$plugin: Warning: area of '$area' does not parallelize (CK limitation)" 1>&2
#				s=1
		fi

		# Use tabs for arg separation and escape-quote $plugin so that when parallel
		# interprets this input line to call ck_wrap it doesn't consume quotes.
		for _s in $(seq -s ' ' $SHARDS_START $s); do
			printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$SRC" "$BUILD" "$OUT" "$CACHE" "$plugin" "$MODE" "$t" "$area" "$area_ck" "$_s" "$s"
		done

	done
done | perl -e '
	# Sort output jobs by largest plugins first so that longer running jobs overlap
	# more with shorter running jobs - making better use of parallelization.

	use warnings FATAL => qw(all);
	use strict;

	use File::Basename qw(basename);
	use List::Util qw(shuffle);

	my %plugins;
	while (<>) {
		chomp;
		my @b = split("\t", $_);
		push @{$plugins{$b[4]}}, $_;
	}

	# Sort by count of CELL records within a plugin
	my $ckgen_dir = "Data/ckgen";
	open(my $fd, "-|", "find Data/*.es[mpl] $ckgen_dir -type f -name \"*.es[mpl]\" -print0 | xargs -r0 grep -Hc CELL") or die;
	my @a = map { chomp; my @b = split(":", $_, 2); [ basename($b[0]), $b[1] ]; } (<$fd>);
	close($fd);

	my %seen;
	foreach (grep !$seen{$_}++, map $_->[0], sort { $b->[1] <=> $a->[1] } @a) {
		print "$_\n" foreach (shuffle @{$plugins{$_}});
	}
' > "$BUILD/tmp/jobs.in"

if [[ ! -s "$BUILD/tmp/jobs.in" ]]; then
	exit 0
fi

if ((MANUAL)); then
	PFLAGS="--res $BUILD/{5}/jobs/{6}/{7}/{8}/{9}/{10}/{11}/ --joblog=$BUILD/tmp/jobs.log --progress --delay 2 --lb -tr -j $JOBS --colsep '\t'"
else
#	PFLAGS="--res $BUILD/tmp/{5}/{6}/{7}/{8}/{9}/{10}/{11}/ --joblog=$BUILD/tmp/jobs.log --eta --shuf --lb -tr -j $JOBS --colsep '\t'"
	PFLAGS="--res $BUILD/{5}/jobs/{6}/{7}/{8}/{9}/{10}/{11}/ --joblog=$BUILD/tmp/jobs.log --progress --lb -tr -j $JOBS --colsep '\t'"
fi

# Note: final 'read' commands are to prevent tmux from closing each sub-window
if ((TMUX)); then
	# Final command to execute after parallel finishes
	PAUSE="read"

	# tmux doesn't emit the exit status of child commands as part of it's own exit status
	touch "$BUILD/tmp/jobs.log"
	rm -f "$BUILD/tmp/parallel.error"
	tmux new \
		"ckgen --log-wrap '$BUILD' cell $JOBS" ';' \
		split -p 40 \
		"ckgen --log-wrap '$BUILD' all $JOBS" ';' \
		split -p 50 \
		"parallel $PFLAGS 'bash -x ckgen --wrap {} {%} $MANUAL $BUILD/tmp/ctl.log' < '$BUILD/tmp/jobs.in'; [[ \$? -ne 255 ]] && $PAUSE || touch '$BUILD/tmp/parallel.error'; cat '$BUILD/tmp/ck_log_wrap'.*.pid | xargs -r kill" ';' \
		set-option status-left "#(ckgen --status '$PWD/$BUILD')" ';' \
		set-option status-interval 1 ';' \
		set-option status-right '' ';' \
		set-option status-left-length 180 ';' \
		set-option status-style fg=black,reverse ';' \
		set-window-option window-status-current-format '' \
		&& [[ ! -f "$BUILD/tmp/parallel.error" ]] \
		|| exit -1
#		set-option alternate-screen off ';' \
#		"set-option status off" ';' \
#		"set -g terminal-overrides 'xterm*:smcup@:rmcup@'" \
else
	parallel $PFLAGS "ckgen --wrap {} {%} $MANUAL $BUILD/tmp/ctl.log" < "$BUILD/tmp/jobs.in" || exit -1
fi

fi


# Process output from build
awk -F'\t' '!seen[$5]++ { print $5 }' "$BUILD/tmp/jobs.in" | while read plugin; do
	plugin_parse "$plugin" plugin t a s
	ck_wrap_proc "$BUILD" "$OUT" "$plugin"
done
