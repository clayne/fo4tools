#!/bin/bash

set -e

[[ -d ckgen.cache/Data ]] || exit -1

for a in ckgen.cache/Data/*.ba2; do
	a="$(basename "$a")"

	[[ -f "Data/$a" ]] && echo "$a" || continue

	mkdir -p ckgen.cache/tmp/Data/{0,1}
	Tools/Archive2/Archive2.exe "Data/$a" -e=ckgen.cache/tmp/Data/0 -q &
	Tools/Archive2/Archive2.exe "ckgen.cache/Data/$a" -e=ckgen.cache/tmp/Data/1 -q &
	wait

	rm -rf ckgen.cache/tmp/Data/0/{Vis,Meshes/{SCOL,PreCombined}}
	rm -rf ckgen.cache/tmp/Data/1/{Vis,Meshes/{SCOL,PreCombined}}
	rmdir --ignore-fail-on-non-empty ckgen.cache/tmp/Data/{0,1}/Meshes &>/dev/null || true

	comm -3 \
		<(cd ckgen.cache/tmp/Data/0 && find | tr '[A-Z]' '[a-z]' | sort) \
		<(cd ckgen.cache/tmp/Data/1 && find | tr '[A-Z]' '[a-z]' | sort) \
			| awk -v a="$a" '{ print a,$0 }'

	rm -rf ckgen.cache/tmp/Data
done
