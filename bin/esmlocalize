#!/bin/bash

while getopts "d" opt; do
        case $opt in
	d) DELOCALIZE=1 ;;
	?) exit -1 ;;
        esac
done; shift $((OPTIND - 1))

for i in "$@"; do
	[[ "$i" =~ .esm || "$i" =~ .esp ]] || continue

	if ((DELOCALIZE)); then
		printf '\x01'
	else
		printf '\x81'

	fi | dd of="$i" bs=1 seek=8 count=1 conv=notrunc
done
