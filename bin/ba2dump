#!/usr/bin/perl

use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling);
use Carp qw(confess);
use Data::Dumper;
use Pod::Usage;

use warnings FATAL => qw(all);
use strict;

local $SIG{__DIE__} = \&confess;
local $Data::Dumper::Sortkeys = 1;

our $VERSION = '$Id$';

my $verbose = 0;

sub main {
	my $ret;
	my $help = 0;
	my $filename = 0;

	local @ARGV = @_;
	GetOptions(
                'h|help' => \$help,
		'verbose|v+' => \$verbose,
		'filename|f+' => \$filename,
        ) && (!$help && ($ret = 1));

        $ret || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	foreach my $ba2_file (@ARGV) {
		my $dump = ($verbose ? 1 : 0);
		my $dump_file = undef;
		my $bsarch_opt = $verbose ? '-dump' : '-list';
		open(my $fd, '-|', "bsarch '$ba2_file' $bsarch_opt 2>&1") or die "open: bsarch: $!";
		while (<$fd>) {
			chomp; s/\R//g;

			if (!$dump) {
				s/\\/\//g || next;
				printf("%s%s\n", $filename ? sprintf("%s\t", $ba2_file) : "", $_);
				next;
			}

			# SCRIPTS\Fragments\Terminals\TERM_BTInt_OPTIONS_Terminal__01070704.pex
			#  DirHash: B118434B  NameHash: 204458F6  Ext: pex  Unknown: 0x00100100
			#  Size: 1593  PackedSize: 625
			if (!$dump_file && s/\\/\//g) {
				$dump_file = $_;
			} elsif ($dump_file && /Size: (\d+)\s+PackedSize: (\d+)/) {
				my ($size, $size_packed) = ($1, $2 ? $2 : $1);
				printf("%s%12d\t%12d\t%12.2f%%\t%s\n",
					$filename ? sprintf("%s\t", $ba2_file) : "",
					$size, $size_packed,
					100.0 - ($size_packed / $size * 100.0),
					$dump_file);
				undef $dump_file;
			}
		}
		close($fd);
	}

	return 1;
}

exit !main(@ARGV) unless (caller);

__END__
