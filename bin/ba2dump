#!/usr/bin/perl

our $VERSION = '$Id$';

use FindBin;
use lib "$FindBin::Bin/../lib";

use TES::Plugin::Common qw(fmt_print);
use TES::Plugin::Archive::BA2 qw();
use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling);
use Carp qw(confess);
use Data::Dumper;
use Pod::Usage;

use strict;
use warnings FATAL => qw(all);

local $SIG{__DIE__} = \&confess;
sub fatal { local $SIG{__DIE__}; die @_, "\n" }

local $Data::Dumper::Sortkeys = 1;

my $crc_decimal;
my $flags_decimal;

my $ent_dump_tab = {
	GNRL => \&ent_gnrl_dump,
	DX10 => \&ent_dx10_dump,
};

sub ent_gnrl_dump {
	my ($ent, %opts) = @_;
	my $verbose = $opts{'verbose'};
	my $filename = $opts{'filename'};
	my $path = $opts{'path'};
	my $out = $opts{'out'};

	if (!$verbose) {
		push @$out, {
			filename => $path,
			name => $ent->name,
		};
		return 1;
	}

	push @$out, {
		filename => $path,
		size => $ent->size,
		packed => $ent->size_packed,
		ratio => sprintf("%6.2f%%", 100.0 - ($ent->size_packed / $ent->size * 100.0)),
		dir_hash => sprintf($crc_decimal ? "%d" : "0x%08x", $ent->dir_hash),
		name_hash => sprintf($crc_decimal ? "%d" : "0x%08x", $ent->name_hash),
		flags => sprintf($flags_decimal ? "%d" : "0x%08x", $ent->flags),
		ext => $ent->extension,
		name => $ent->name,
	};

	return 1;
}

sub ent_dx10_dump {
	my ($ent, %opts) = @_;
	my $verbose = $opts{'verbose'};
	my $filename = $opts{'filename'};
	my $path = $opts{'path'};
	my $out = $opts{'out'};

	if (!$verbose) {
		push @$out, {
			filename => $path,
			name => $ent->name,
		};
		return 1;
	}

	push @$out, {
		filename => $path,
		size => $ent->size,
		packed => $ent->size_packed,
		ratio => sprintf("%6.2f%%", 100.0 - ($ent->size_packed / $ent->size * 100.0)),
		dir_hash => sprintf($crc_decimal ? "%d" : "0x%08x", $ent->dir_hash),
		name_hash => sprintf($crc_decimal ? "%d" : "0x%08x", $ent->name_hash),
		flags => sprintf($flags_decimal ? "%d" : "0x%08x", $ent->flags),
		height => $ent->height,
		width => $ent->width,
		cmap => $ent->cubemaps,
		dxgi => $ent->dxgi_format,
		mips => $ent->mip_count,
		ext => $ent->extension,
		name => $ent->name,
	};

	if ($verbose > 1) {
		$ent->chunk_proc(sub {
			my $chunk = shift;

			push @$out, {
				size => $chunk->size,
				packed => $chunk->size_packed,
				ratio => sprintf("%6.2f%%", 100.0 - ($chunk->size_packed / $chunk->size * 100.0)),
				mips => ($chunk->mip_start != $chunk->mip_end)
					? sprintf("%d-%d", $chunk->mip_start, $chunk->mip_end)
					: sprintf("%d", $chunk->mip_start),
			};
		});
	}

	return 1;
}

sub main {
	my $ret;
	my $help = 0;
	my $header = 2;
	my $verbose = 0;
	my $filename = 0;
	my $sort;

	local @ARGV = @_;
	GetOptions(
                'h|help' => \$help,
		'verbose|v+' => \$verbose,
		'header!' => \$header,
		'filename|l+' => \$filename,
		'sort|s:s' => \$sort,
		'crc-decimal' => \$crc_decimal,
		'flags-decimal' => \$flags_decimal,,
        ) && (!$help && ($ret = 1));

        $ret || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	return 1 unless (@ARGV);

	my $has_dx10 = grep /Textures/, @ARGV;

	my $fmt_sep = ' | ';
	my $fmt_tab;
	my $fmt_tab_extra;
	if (!$verbose) {
		$header = 0;
		$fmt_sep = "\t";
		$fmt_tab = [
			$filename ? [ filename => 0 ] : (),
			[ name => 0 ],
		];
	} else {
		$fmt_tab = [
			$filename ? [ filename => 0 ] : (),
			[ size => 10 ],
			[ packed => 10 ],
			[ ratio => 8 ],
			[ dir_hash => 10 ],
			[ name_hash => 10 ],
			[ flags => 10 ],
		];

		if ($has_dx10 && $verbose == 1) {
			$fmt_tab_extra = [
				[ height => 6 ],
				[ width => 6 ],
				[ mips => 4 ],
			];
		} elsif ($has_dx10) {
			$fmt_tab_extra = [
				[ height => 6 ],
				[ width => 6 ],
				[ cmap => 8 ],
				[ dxgi => 4 ],
				[ mips => 4 ],
			];
		}

		push @$fmt_tab, $fmt_tab_extra ? @$fmt_tab_extra : (),
			[ ext => 4 ],
			[ name => 0 ];
	}

	my $out = [];
	foreach (@ARGV) {
		my $ba2 = TES::Plugin::Archive::BA2->read($_) or die;
		my $type = $ba2->type;
		my $proc_cb = $ent_dump_tab->{$type} || die;

		$ba2->ent_proc($proc_cb,
			path => $_,
			verbose => $verbose,
			filename => $filename,
			sort => $sort,
			out => $out,
		);
	}

	binmode(STDOUT, ":utf8");

	fmt_print($out, $fmt_tab, $fmt_sep, $header && !($header = 0));

	return 1;
}

exit !main(@ARGV) unless (caller);

__END__
