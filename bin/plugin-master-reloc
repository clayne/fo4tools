#!/usr/bin/perl

use TES::Plugin::Common qw(file_sub file_clone file_join);
use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling);
use Carp qw(confess);
use File::Basename qw(basename dirname);
use File::Copy qw(cp);
use Data::Dumper;
use Pod::Usage;

use strict;
use warnings FATAL => qw(all);

local $SIG{__DIE__} = \&confess;

local $Data::Dumper::Sortkeys = 1;

our $VERSION = '$Id$';

my %protect_tab = map +($_ => 1), qw(
	Fallout4.esm
	DLCRobot.esm
	DLCworkshop01.esm
	DLCCoast.esm
	DLCworkshop02.esm
	DLCworkshop03.esm
	DLCNukaWorld.esm
	DLCUltraHighResolution.esm
);

my $verbose = 0;
my $quick = 0;
my $noop = 0;
my $esm_to_esp = 0;
my $esp_to_esm = 0;
my $copy_plugin_to_esm = 0;
my $copy_plugin_to_esp = 0;
my $unlink = 1;
my $protect = 1;
my $esp_only = 0;
my $esm_only = 0;
my $recurse = 0;
my $hex = 0;
my $include_self = 0;
my $timestamp_inc;
my $overwrite = 0;
my $sub_smart = 1;
my @sub;
my $abs_path;
my $all;

sub global_reset {
	$verbose = 0;
	$quick = 0;
	$noop = 0;
	$esm_to_esp = 0;
	$esp_to_esm = 0;
	$copy_plugin_to_esm = 0;
	$copy_plugin_to_esp = 0;
	$unlink = 1;
	$protect = 1;
	$esp_only = 0;
	$esm_only = 0;
	$recurse = 0;
	$hex = 0;
	$include_self = 0;
	$overwrite = 0;
	$sub_smart = 1;
	@sub = ();
	$timestamp_inc = undef;
	$abs_path = undef;
	$all = undef;
}

# XXX: This can be done better
my $flags_tab = [ 'esm', undef, undef, undef, undef, undef, undef, 'localized', undef, 'esl' ];
sub flags_str {
	my ($flags) = @_;
	my @out;

	for (my $i = 0; $i < 32; $i++) {
		next unless ($flags_tab->[$i] && ($flags & (0x1 << $i)));
		push @out, $flags_tab->[$i];
	}

	return join(', ', @out);
}

sub master_write {
	my ($path, $offset, $master) = @_;

	my @stat = stat($path) or die "stat: $!: $path";
	open(my $fd, '+<', $path) or die "open: $!: $path";
	seek($fd, $offset, 0) or die "seek: $!";

	my $len = !$noop
		? (syswrite($fd, $master, length($master)) or die "syswrite: $!")
		: length($master);

	close($fd);

	if ($timestamp_inc) {
		utime($timestamp_inc, $timestamp_inc, $path) or die "utime: $path: $!";
		$timestamp_inc++;
	} else {
		utime($stat[8], $stat[9], $path) or die "utime: $path: $!";
	}
}

sub parent_queue {
	my ($q, $parents, $parent) = @_;
	if (!$parents->{$parent}) { unshift @$q, $parent }
	else { push @$q, $parent }
}

sub plugin_proc {
	my ($target, %opts) = @_;

	my %seen;
	my @unlink;
	my $mout = [];
	my $parents = {};

	my @q = $target;
	while (local $_ = shift @q) {
		my ($dirname, $basename, $path) = (dirname($_), basename($_), $_);
		my $path_key = $abs_path ? $path : $basename;
		next unless (!$seen{$path_key}++);

		# Defend against vanilla esm files mistakenly being used.
		my $is_protected = ($protect && $protect_tab{$basename});
		if (!$is_protected && $copy_plugin_to_esm) {
			my $plugin = file_sub($basename, sub_ext => [ 'esp', 'esm' ], sub => \@sub);
			if ($plugin ne $basename) {
				my $src = file_join($dirname, $basename);
				my $dst = file_join($dirname, $plugin);

				file_clone($src, $dst, overwrite => $overwrite);

				# Place the cloned plugin into the queue as a target for
				# updating rather than the original plugin.
				unshift @q, $dst;
				next;
			}
		} elsif (!$is_protected && $copy_plugin_to_esp) {
			my $plugin = file_sub($basename, sub_ext => [ 'esm', 'esp' ], sub => \@sub);
			if ($plugin ne $basename) {
				my $src = file_join($dirname, $basename);
				my $dst = file_join($dirname, $plugin);

				file_clone($src, $dst, overwrite => $overwrite);

				# Place the cloned plugin into the queue as a target for
				# updating rather than the original plugin.
				unshift @q, $dst;
				next;
			}
		}

		print STDERR Dumper $path if ($verbose > 1);

		my $fd;
		if ($path eq '/dev/stdin' || $path eq '-') {
			$fd = *STDIN;
			$esm_to_esp = 0;
			$esp_to_esm = 0;
			$unlink = 0;
		} else {
			open($fd, '<', $path) or ($noop ? next : die "open: $!: $path");
		}

		my ($off, $len, $bsz, $buf) = (0, 0, 0);
		$len = sysread($fd, $buf, 4096) or die "sysread: $!";
		print STDERR Dumper length($buf) if ($verbose > 1);

		# Read initial TES4 header to get it's overall length
		$bsz = 8; my ($sig, $sz) = unpack("a4 L", substr($buf, $off, $bsz)); $off += $bsz;
		if ($sig ne 'TES4') {
			next;
		} elsif ($sz + 8 > $len) {
			printf STDERR ("Reading %d additional bytes\n", ($sz + 8) - $len) if ($verbose > 1);
			$len += sysread($fd, $buf, ($sz + 8) - $len, $len) or die "sysread: $!";
		}

		# Read contents of TES4
		$bsz = 16; my ($flags, $formid, $vc1, $vf, $vc2) = unpack("L L L S S", substr($buf, $off, $bsz)); $off += $bsz;
		print STDERR Dumper { sig => $sig, sz => $sz, flags => $flags, formid => $formid, vc1 => $vc1, vf => $vf, vc2 => $vc2 } if ($verbose > 1);

		# Read any MAST records within TES4 and add the offset and
		# filename to a list of masters
		my $mproc = [];
		while ($off < $sz) {
			$bsz = 6; my ($sig, $sz) = unpack("a4 S", substr($buf, $off, $bsz)); $off += $bsz;
			print STDERR Dumper[$sig,$sz] if ($verbose > 1);

			if ($sig ne 'MAST') {
				$off += $sz;
				next;
			}

			my $off_save = $off;
			my $ssz = $sz - 1; # Ignore NUL
			$bsz = $sz; my ($file) = unpack("a$ssz", substr($buf, $off, $bsz)); $off += $bsz;

			print STDERR Dumper [$off_save,$file] if ($verbose > 1);
			push @$mproc, { offset => $off_save, master => $file, plugin => $basename };
			if ($basename eq basename($target)) {
				$parents->{$file}++;
			}
		}
		close($fd) or die "close: $!";

		unshift @$mout, { path => $_, size => $sz, flags => $flags, dirname => $dirname, basename => $basename, mproc => $mproc };

		for (my $i = @$mproc; $i--; ) {
			my ($offset, $master) = map $mproc->[$i]{$_}, qw(offset master);
			my $master_new = $master;

			if (!$is_protected && $esp_to_esm) {
				# For any file with esp masters, copy the esp to an esm
				# extension and update the MAST entry to point to it.
				# Additionally, for each esp master, add it to the list of
				# files to process so any of their parent esp masters will
				# be substituted accordingly.

				if ($master =~ /\.esm$/i) {
					# Possible to have an esp with an esm master. Pass
					# it on to check just in case. Vanilla files will
					# be ignored by the protect list.
					if ($recurse) {
						my $parent = file_join($dirname, $master);
						parent_queue(\@q, $parents, $parent);
					}
					next;
				}

				$master_new = file_sub($master, sub_ext => [ 'esp', 'esm' ], sub => \@sub);
				if ($master_new ne $master) {
					# Clone master that MAST entry will point to
					my $src = file_join($dirname, $master);
					my $dst = file_join($dirname, $master_new);
					file_clone($src, $dst, overwrite => (0 && $overwrite)); # XXX: Sort out overwrite race

					# Update MAST to point to esm file by cloning and reopening for write
					file_clone($path, $path, overwrite => $overwrite);

					printf STDERR ($hex ? "Writing \"%s\": [%02X] %s%s\n" : "Writing \"%s\": [%02d] %s%s\n",
						$basename, $i, $master_new, $noop ? ' (noop)' : '') if ($verbose);

					master_write($path, $offset, $master_new);

					$mproc->[$i]{'master'} = $master_new;
				}
			} elsif (!$is_protected && $esm_to_esp) {
				# For any file with esm masters which have a matching esp
				# file, update the MAST entry to point to the esp and remove
				# the esm. The matching esp check is very important so as not
				# to remove esms which were unlikely to be generated by this
				# script.

				if ($master =~ /\.esp$/i) {
					# Possible to have an esm with an esp master. Pass
					# it on to check just in case. Vanilla files will
					# be ignored by the protect list.
					if ($recurse) {
						my $parent = file_join($dirname, $master);
						parent_queue(\@q, $parents, $parent);
					}
					next;
				}

				# If there is no matching esp file for the esm master being
				# rewritten back to esp, then it was never an esp in the first
				# place and should be completely ignored.
				$master_new = undef;
				foreach my $ext (qw(esp esm)) {
					my $__master_new = file_sub($master, sub_ext => [ 'esm', $ext ], sub => \@sub);

					# If the renamed master is the same as the existing
					# master *or* the renamed master does not exist, then
					# no modification should be done. This is important.
					if (-f file_join($dirname, $__master_new)) {
						$master_new = $__master_new;
						last;
					}
				}
				next unless ($master_new);

				# If no esp could be resolved or the file is the same, skip modifying
				# this plugin to point to it but still pass it on to be checked for
				# MAST entries within said master.
				if ($master_new ne $master) {
					# Update MAST to point to esp file by cloning and reopening for write
					file_clone($path, $path, overwrite => $overwrite);

					printf STDERR ($hex ? "Writing \"%s\": [%02X] %s%s\n" : "Writing \"%s\": [%02d] %s%s\n",
						$basename, $i, $master_new, $noop ? ' (noop)' : '') if ($verbose);

					master_write($path, $offset, $master_new);

					$mproc->[$i]{'master'} = $master_new;

					# The only esms which will be removed are those which
					# have matching esp files and those which were resolved
					# from masters present in the arg list.
					if (-f file_join($dirname, $master_new)) {
						push @unlink, file_join($dirname, $master);
					}
				}
			}

			if ($recurse) {
				my $parent = file_join($dirname, $master_new);
				parent_queue(\@q, $parents, $parent);
			}
		}
	}

	my %unlink = ();
	foreach (grep !$unlink{$_}++, @unlink) {
		if ($protect && $protect_tab{basename($_)}) {
			die "Assertion failed: attempt to unlink protected file: $_";
		}

		-f $_ || next;
		print STDERR "unlink $_\n" if ($verbose);
		if ($noop) {
			print STDERR "unlink: $_\n";
		} else {
			unlink($_) or die "unlink: $!";
		}
	}

	%seen = ();
	my $head;
	foreach my $ent (@$mout) {
		my ($path, $size, $flags, $dirname, $basename, $mproc)
			= map $ent->{$_}, qw(path size flags dirname basename mproc);
		next if ($unlink{$path});

		if ($verbose) {
			my @add;
			push @add, [ 'size', $size, 0 ] if (defined $size);
			push @add, [ 'flags', flags_str($flags), 1 ] if ($flags);
			printf STDERR ("\n") if ($head++);
			printf STDERR ("%s (%s):\n", $path, join(', ', map {
				my ($label, $value, $bracket) = @$_;
				sprintf("%s: %s", $label, $bracket ? "[$value]" : $value);
			} @add));
		}

		if ($all || $include_self) {
			push @$mproc, { offset => 0, master => $basename, plugin => $basename };
		}

		for (my $i = 0; $i < @$mproc; $i++) {
			my ($offset, $master, $plugin) = map $mproc->[$i]{$_}, qw(offset master plugin);

			next if ($esp_only && $master !~ /\.esp$/);
			next if ($esm_only && $master !~ /\.esm$/);
			next if (!$include_self && basename($master) eq basename($target));

			if ($verbose) {
				printf STDERR ($hex ? "[%02X] %s%s\n" : "[%02d] %s%s\n",
					$i, $master, $plugin ne $basename ? " ($plugin)" : "");
			} elsif (!$esp_to_esm && !$esm_to_esp) {
				if (!$quick) {
					next unless (!$seen{join('.', $path, $master)}++);
					printf STDOUT ("%s\t%s\n", $path, $master);
				} elsif ($abs_path) {
					my $master_path = file_join($dirname, $master);
					next unless (!$seen{$master_path}++);
					printf STDOUT ("%s\n", $master_path);
				} else {
					next unless (!$seen{$master}++);
					printf STDOUT ("%s\n", $master);
				}
			}
		}
	}

	return 1;
}

sub main {
	my $help = 0;

	global_reset;

	local @ARGV = @_;
	GetOptions(
		'h|help' => \$help,
		'q|quick+' => \$quick,
		'v|verbose+' => \$verbose,
		'n|dry-run+' => \$noop,
		'unlink!' => \$unlink,
		'protect!' => \$protect,
		'copy-plugin-to-esm' => \$copy_plugin_to_esm,
		'copy-plugin-to-esp' => \$copy_plugin_to_esp,
		'esp|esm-to-esp+' => \$esm_to_esp,
		'esm|esp-to-esm+' => \$esp_to_esm,
		'esp-only+' => \$esp_only,
		'esm-only+' => \$esm_only,
		'f|overwrite+' => \$overwrite,
		'r|recurse+' => \$recurse,
		's|include-self' => \$include_self,
		'A|abs-path+' => \$abs_path,
		'a|all+' => \$all,
		'smart-sub+' => \$sub_smart,
		'sub=s' => \@sub,
		'timestamp-inc:i' => \$timestamp_inc,
		'H|hex+' => \$hex,
	) && !$help || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	$timestamp_inc ||= time if (defined $timestamp_inc);

	if ($copy_plugin_to_esp && $copy_plugin_to_esm) {
		die "Both copy_plugin_to_esp and copy_plugin_to_esm specified\n";
	}

	foreach (@ARGV ?  @ARGV : '-') {
		plugin_proc($_);
	}

	return 1;
}

exit !main(@ARGV) unless (caller);

__END__

