#!/usr/bin/perl

use Getopt::Long qw(:config no_ignore_case no_auto_abbrev bundling);
use Carp qw(confess);
use File::Basename qw(basename dirname);
use File::Copy qw(copy);
use Data::Dumper;
use Pod::Usage;

use warnings FATAL => qw(all);
use strict;

local $SIG{__DIE__} = \&confess;
local $Data::Dumper::Sortkeys = 1;

our $VERSION = '$Id$';

my $verbose = 0;
my %blacklist_tab = map +($_ => 1), qw(
	Fallout4.esm
	DLCRobot.esm
	DLCworkshop01.esm
	DLCCoast.esm
	DLCworkshop02.esm
	DLCworkshop03.esm
	DLCNukaWorld.esm
	DLCUltraHighResolution.esm
);

sub clone {
	my ($src, $dst, $overwrite) = @_;

	if (! -f $dst || $overwrite) {
		if (-f $dst) { unlink($dst) or die "unlink: $!" }

		# Copy src to dst and clone atime/mtime.
		my @stat = stat($src) or die "stat: $!";
		copy($src, $dst) or die "$src -> $dst";
		utime($stat[8], $stat[9], $dst) or die "utime: $!";
	}
}

sub main {
	my $ret;
	my $help = 0;
	my $quick = 0;
	my $esm_to_esp = 0;
	my $esp_to_esm = 0;
	my $copy_plugin_to_esm = 0;
	my $copy_plugin_to_esp = 0;
	my $unlink = 1;
	my $blacklist = 1;
	my $esp_only = 0;
	my $esm_only = 0;

	local @ARGV = @_;
	GetOptions(
                'h|help' => \$help,
		'quick|q+' => \$quick,
		'verbose|v+' => \$verbose,
		'unlink!' => \$unlink,
		'blacklist!' => \$blacklist,
		'copy-plugin-to-esm' => \$copy_plugin_to_esm,
		'copy-plugin-to-esp' => \$copy_plugin_to_esp,
		'esp|esm-to-esp+' => \$esm_to_esp,
		'esm|esp-to-esm+' => \$esp_to_esm,
		'esp-only+' => \$esp_only,
		'esm-only+' => \$esm_only,
        ) && (!$help && ($ret = 1));

        $ret || pod2usage(-verbose => 2, -noperldoc => 1, -exitval => -1);

	my $head;
	my %seen;
	my @unlink;

	# Defend against esm files mistakenly being used.
	my @q = (@ARGV ?  @ARGV : '-');
	while (local $_ = shift @q) {
		my $mtab = [];
		my ($dirname, $basename) = (dirname($_), basename($_));

		next unless (!$seen{$basename}++);
		next unless (!$blacklist || !$blacklist_tab{$basename});

		if ($copy_plugin_to_esm) {
			my $esp = $basename;
			if ($esp =~ /\.esp/i) {
				my $esm = ($esp =~ s/\.esp$/\.esm/r);
				clone("$dirname/$esp", "$dirname/$esm");
				unshift @q, "$dirname/$esm";
				next;
			}
		} elsif ($copy_plugin_to_esp) {
			my $esm = $basename;
			if ($esm =~ /\.esm/i) {
				my $esp = ($esm =~ s/\.esm$/\.esp/r);
				clone("$dirname/$esm", "$dirname/$esp");
				unshift @q, "$dirname/$esp";
				next;
			}
		}

		printf STDERR ("%s%s:\n", $head++ ? "\n" : "", $_) if ($verbose);

		my $fd;
		if ($_ eq '-') {
			$fd = *STDIN;
			$esm_to_esp = 0;
			$esp_to_esm = 0;
			$unlink = 0;
		} else {
			open($fd, ($esm_to_esp || $esp_to_esm) ? '+<' : '<', $_) or die "open: $!:";
		}

		my ($off, $len, $bsz, $buf) = (0, 0, 0);
		$len = sysread($fd, $buf, 4096) or die "sysread: $!";
		print STDERR Dumper length($buf) if ($verbose > 1);

		# Read initial TES4 header to get it's overall length
		$bsz = 8; my ($sig, $sz) = unpack("a4 L", substr($buf, $off, $bsz)); $off += $bsz;
		if ($sig ne 'TES4') {
			next;
		} elsif ($sz + 8 > $len) {
			printf STDERR ("Reading %d additional bytes\n", ($sz + 8) - $len) if ($verbose > 1);
			$len += sysread($fd, $buf, ($sz + 8) - $len, $len) or die "sysread: $!";
		}

		# Read contents of TES4
		$bsz = 16; my ($flags, $formid, $vc1, $vf, $vc2) = unpack("L L L S S", substr($buf, $off, $bsz)); $off += $bsz;
		print STDERR Dumper { sig => $sig, sz => $sz, flags => $flags, formid => $formid, vc1 => $vc1, vf => $vf, vc2 => $vc2 } if ($verbose > 1);

		# Read any MAST records within TES4 and add the offset and
		# filename to a list of masters
		while ($off < $sz) {
			$bsz = 6; my ($sig, $sz) = unpack("a4 S", substr($buf, $off, $bsz)); $off += $bsz;
			print STDERR Dumper[$sig,$sz] if ($verbose > 1);

			if ($sig eq 'MAST') {
				my $off_save = $off;
				my $ssz = $sz - 1; # Ignore NUL
				$bsz = $sz; my ($file) = unpack("a$ssz", substr($buf, $off, $bsz)); $off += $bsz;

				print STDERR Dumper [$off_save,$file] if ($verbose > 1);
				push @$mtab, [ $off_save, $file ];
			} else {
				$off += $sz;
			}
		}

		my @qt;
		for (my $i = 0; $i < @$mtab; $i++) {
			next if ($esp_only && $mtab->[$i][1] !~ /\.esp$/);
			next if ($esm_only && $mtab->[$i][1] !~ /\.esm$/);

			if ($verbose) {
				printf STDERR ("[%02d] %s\n", $i, $mtab->[$i][1]);
			} elsif (!$esp_to_esm && !$esm_to_esp) {
				if (!$quick) {
					printf STDOUT ("%s\t%s\n", $basename, $mtab->[$i][1]);
				} else {
					printf STDOUT ("%s\n", $mtab->[$i][1]);
				}
			}
		}

		for (my $i = 0; $i < @$mtab; $i++) {
			my ($off, $plugin) = @{$mtab->[$i]};

			if ($esp_to_esm) {
				# For any file with esp masters, copy the esp to an esm
				# extension and update the MAST entry to point to it.
				# Additionally, for each esp master, add it to the list of
				# files to process so any of their parent esp masters will
				# be substituted accordingly.

				my $esp = $plugin;
				next if ($esp =~ /\.esm/i);

				my $esm = ($esp =~ s/\.esp$/\.esm/r);
				clone("$dirname/$esp", "$dirname/$esm");

				# Update MAST to point to esm file
				seek($fd, $off, 0) or die "seek: $!";
				my $len = syswrite($fd, $esm, length($esm)) or die "syswrite: $!";
				printf STDERR ("Writing %s: [%02d] %s\n", $basename, $i, $esm) if ($verbose);

				push @qt, "$dirname/$esm";
			} elsif ($esm_to_esp) {
				# For any file with esm masters which have a matching esp
				# file, update the MAST entry to point to the esp and remove
				# the esm. The matching esp check is very important so as not
				# to remove esms which were unlikely to be generated by this
				# script.

				my $esm = $plugin;
				next if ($esm =~ /\.esp/i);

				my $esp = ($esm =~ s/\.esm$/\.esp/r);
				next if (! -f "$dirname/$esp"); # CRITICAL

				# Update MAST to point to esp file.
				seek($fd, $off, 0) or die "seek: $!";
				my $len = syswrite($fd, $esp, length($esp)) or die "syswrite: $!";
				printf STDERR ("Writing %s: [%02d] %s\n", $basename, $i, $esp) if ($verbose);

				# The only esms which will be removed are those which
				# have matching esp files and those which were resolved
				# from masters present in the arg list.
				next if (! -f "$dirname/$esm");
				push @unlink, "$dirname/$esm";
				push @qt, "$dirname/$esm";
			}
		}

		unshift @q, @qt;
		close($fd);
	}

	%seen = ();
	foreach (grep !$seen{$_}++, @unlink) {
		if ($blacklist && $blacklist_tab{basename($_)}) {
			die "Assertion failed: attempt to unlink blacklisted file: $_";
		}

		-f $_ || next;
		print STDERR "unlink $_\n" if ($verbose);
		unlink($_) or die "unlink: $!";
	}

	return 1;
}

exit !main(@ARGV) unless (caller);

__END__

