#!/bin/bash

set -e
set -o pipefail

source "$HOME/git/fo4tools/etc/fo4tools.conf" || source /usr/local/etc/fo4tools.conf
source "$HOME/git/fo4tools/etc/ckgen.conf" || source /usr/local/etc/ckgen.conf

if [[ -z "$CKGEN_BUILD_DIR" ]]; then
	echo "Unable to resolve ckgen build directory" 1>&2
	exit -1
elif [[ -z "$CKGEN_CACHE_DIR" ]]; then
	echo "Unable to resolve ckgen cache directory" 1>&2
	exit -1
elif [[ -z "$CKGEN_DATA_DIR" ]]; then
	echo "Unable to resolve ckgen data directory" 1>&2
	exit -1
elif [[ -z "$CKGEN_OUT_DIR" ]]; then
	echo "Unable to resolve ckgen output directory" 1>&2
	exit -1
fi

# Force Windows (rather than Cygwin) compatible symlinks
export CYGWIN=winsymlinks:nativestrict

# Prereq check
for i in rsync; do
	if ! which $i &>/dev/null; then
		echo "$i not found" 1>&2
		exit -1
	fi
done

function data_clone() {
	local src="$1"; shift
	local dst="$1"; shift

#	rm -rf "$dst" && mkdir -p "$dst"
	mkdir -p "$dst"

	# TODO: exclude base- or pcv related data

	# Copy plugins so xedit can work with them directly
	rsync -aSH --include="*.es[pml]" --exclude="*" --delete "$src"/ "$dst"/

	# Hard link assets so xedit can find localized string files
	rsync -aSH --exclude="*.es[pml]" --exclude="Merging" --delete --link-dest="$PWD/$src" "$src"/ "$dst"/
}

PLUGINS_FILE_BASE="plugins.pcvgen.base"
PLUGINS_FILE="plugins.pcvgen"
SELF="$(basename "$0")"
OIFS="$IFS"
MODE="final"
SRC="$PWD"

while getopts "aif:m:p:bFR" opt; do
	case $opt in
	a) ALL=1 ;;
	i) INTERACTIVE=1 ;;
	f) PLUGINS_FILE="$OPTARG" ;;
	m) MODE="$OPTARG" ;;
	p) PROFILE="$OPTARG" ;;
	b) MODE="base" ;;
	F) FORCE=1 ;;
	R) RESUME=1 ;;
	?) exit -1 ;;
	esac
done; shift $((OPTIND - 1))

# XXX: Make this reusable between ckgen and pcvgen
if [[ -n "$PROFILE" ]]; then
	if [[ ! -d "$PROGDIR/Fallout 4.$PROFILE" ]]; then
		echo "'$PROGDIR/Fallout 4.$PROFILE' does not exist" 1>&2
		exit -1
	fi

	SRC="$PROGDIR/Fallout 4.$PROFILE"
	if ! cd "$SRC"; then
		echo "Unable to chdir to '$SRC'" 1>&2
		exit -1
	fi
fi

if [[ ! -d "$SRC/Data" || ! -x "$SRC/CreationKit.exe" ]]; then
	echo "'$SRC' is not a Fallout4 related directory" 1>&2
	exit -1
elif [[ -d "$CKGEN_OUT_DIR" ]] && ((!FORCE && !RESUME)); then
	echo "'$CKGEN_OUT_DIR' exists but force option not given" 1>&2
	exit -1
fi

STATE_DIR="/tmp/$SELF/$PROFILE.$MODE"
((RESUME)) || rm -rf "$STATE_DIR"
mkdir -p "$STATE_DIR"

STATE=ckgen_clean; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
	rm -rf "$CKGEN_BUILD_DIR" "$CKGEN_OUT_DIR" "$CKGEN_CACHE_DIR"
	touch "$STATE_DIR/$STATE"
fi

case "$MODE" in
base)
	log_prefix="pcvgen_xe"
	plugin_output_base_combined_prefix="base-"
	master_base_list=()
	ckgen_scol_args=()
	ckgen_args=()

	if ((ALL)); then
		area=( all )
	else
		area=( main ints other )
	fi

	STATE=ckgen_data_clone; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
		# copy orig plugins if not already present
		for i in "${area[@]}"; do
			data_clone "Data" "$CKGEN_DATA_DIR/$i"
		done
		touch "$STATE_DIR/$STATE"
	fi

	# grab base plugins from plugins file
	if [[ -s "$PLUGINS_FILE_BASE" ]]; then
		IFS=$'\n' master_base_list=( $(grep '^\*' "$PLUGINS_FILE_BASE" | tr -d '*') ); IFS="$OIFS"
	fi

	STATE=pcv_init; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
		# build base esps
		cat "$PLUGINS_FILE_BASE" "$PLUGINS_FILE" \
			| pcvgen_xe -v ${INTERACTIVE:+-i} ${ALL:+-a all} \
				--plugins=- \
				--pcv-mode='master_clean' \
				--pcv-plugin-base-process \
				--pcv-plugin-base-master-force \
				--pcv-plugin-base-esm \
				--pcv-plugin-output-log-use \
				--pcv-plugin-output-each-use \
				--pcv-plugin-output-base-combined-use \
				--pcv-plugin-output-base-combined-esm \
				--pcv-plugin-output-base-combined-prefix="${plugin_output_base_combined_prefix}" \
				--pcv-plugin-master-force-list-add="${plugin_output_base_combined_prefix}\$area.pcv.esp" \
				"${master_base_list[@]/#/--pcv-plugin-master-base-list-add=}"
		touch "$STATE_DIR/$STATE"
	fi

	# XXX: hack, figure out a better way - this won't work for pcv generated plugins
	# XXX: with SCOL overrides for instance.
	IFS=$'\n' ckgen_scol_args=( $(fgrep -l 'SCOL' "Data"/*.es[pml] || true) ); IFS="$OIFS"

	# add target plugins as args
	for i in "${area[@]}"; do
		[[ -f "$log_prefix.master_clean.$i.out" ]] || continue
		IFS=$'\n' tmp=( $(tr -d '\r' < "$log_prefix.master_clean.$i.out") ); IFS="$OIFS"

		for j in "${tmp[@]}"; do
			if [[ "$j" =~ ^base.*pcv\.esp ]]; then
				ckgen_base_args+=( "$j:$i@all" )
			else
				ckgen_args+=( "$j:$i@all" )
			fi
			ckgen_files+=( "$CKGEN_DATA_DIR/$i/$j" )
		done
	done

	for mode in scol precombine previs cdx csg; do
		case "$mode" in
		scol)
			STATE="${mode}_pre"; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
				if ((!ALL)); then
					mkdir -p "$CKGEN_DATA_DIR/all"
					cp -lfpt "$CKGEN_DATA_DIR/all" "${ckgen_scol_args[@]}"
				fi
				touch "$STATE_DIR/$STATE"
			fi

			STATE="${mode}_gen"; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
				ckgen -nj16 ${PROFILE:+-p $PROFILE} "$mode" "${ckgen_scol_args[@]}"
				touch "$STATE_DIR/$STATE"
			fi
			;;
		precombine|previs)
			STATE="${mode}_gen"; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
				# build precombines or previs for all base plugins (~1-2h)
				ckgen -nj12 ${PROFILE:+-p $PROFILE} "$mode" \
					clean all "${ckgen_base_args[@]}" \
					filtered all "${ckgen_args[@]}"
				touch "$STATE_DIR/$STATE"
			fi

			STATE="${mode}_merge"; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
				# copy generated precombine or previs plugins back into $CKGEN_DATA_DIR dirs
				# and merge precombine or previs data back into base plugins
				for i in "${ckgen_base_args[@]}" "${ckgen_args[@]}"; do
					d="${i/:*}"; d="${d/.esp.*/.esp}"; d="${d/.esm.*/.esm}"; d="${d/.esl.*/.esl}";
					a="${i/*:}"; a="${a/@*}"

					# XXX: check for missing output files and emit warnings
					[[ -d "$CKGEN_OUT_DIR/$d" ]] || continue
					find "$CKGEN_OUT_DIR/$d" -type f -name "*.${mode}.*.${a}.*.es[pml]" -print0 | xargs -tr0 cp -lfpt "$CKGEN_DATA_DIR/$a"
					find "$CKGEN_OUT_DIR/$d" -type f -name "*.${mode}.*.${a}.*.es[pml]" -printf '%f\n'
				done | pcvgen_xe -v ${INTERACTIVE:+-i} ${ALL:+-a all} \
					--plugins=- \
					--pcv-mode="${mode}_merge" \
					--pcv-plugin-output-combined-use
				touch "$STATE_DIR/$STATE"
			fi
			;;
		cdx|csg)
			STATE="${mode}_gen"; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
				# generate cdx data or compress psg for base plugins
				ckgen -nj12 ${PROFILE:+-p $PROFILE} "$mode" "${ckgen_base_args[@]}"
				touch "$STATE_DIR/$STATE"
			fi
			;;
		esac

	done

# XXX: needs to be some kind of extract precombines/previs to final plugin step here.
# XXX: also needs to copy ba2s for any SCOL data or something else needs to be figured out.
exit -1
	STATE=pcv_final; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
		touch "$STATE_DIR/$STATE"
	fi

	STATE=pcv_final_copy; if [[ ! -f "$STATE_DIR/$STATE" ]]; then
		# copy base plugin esps, geometry, archive, and cdx files into Data
		for i in "${ckgen_base_args[@]}" "${ckgen_args[@]}"; do
			d="${i/:*}"; d="${d/.esp.*/.esp}"; d="${d/.esm.*/.esm}"; d="${d/.esl.*/.esl}";
			a="${i/*:}"; a="${a/@*}"

			[[ -d "$CKGEN_OUT_DIR/$d" ]] || continue
			find "$d" -type f '(' -name '*.[cp]sg' -o -name '*.ba2' -o -name '*.cdx' ')' -print0 | xargs -tr0 cp -lfpt "Data"/

			[[ -d "$CKGEN_DATA_DIR/$a" ]] || continue
			find "$CKGEN_DATA_DIR/$a" -type f -name "${plugin_output_base_combined_prefix}${i}.pcv.esp" -print0 | xargs -tr0 cp -lfpt "Data"/
		done

		touch "$STATE_DIR/$STATE"
	fi

	# extract all precombine/previs data into final plugins (not necessary with base)
	# ensure base plugins are renamed to esm's and flagged correctly
	# use base plugins in plugins.txt

	;;
final)
	;;
esac
